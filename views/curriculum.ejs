<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Scheme Main Table</title>
    <style>
        body {
            padding: 20px;
            font-family: Arial, sans-serif;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            margin-bottom: 20px;
        }
        th, td {
            border: 1px solid #888;
            padding: 8px;
            text-align: left;
        }
        .header-row {
            background-color: #e2efda;
            font-weight: bold;
        }
        .total-row {
            font-weight: bold;
        }
        .center { text-align: center; }
        .back-btn {
            display: inline-block;
            margin-bottom: 20px;
            padding: 10px 20px;
            background: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }
        .back-btn:hover {
            background: #5a6268;
        }
        .guide-box {
            background: #fff8e1;
            border: 1px solid #ffeeba;
            border-radius: 6px;
            padding: 15px 20px;
            margin-bottom: 20px;
            color: #856404;
        }
        .guide-box h3 {
            margin: 0 0 10px 0;
            font-size: 16px;
            color: #856404;
        }
    </style>
</head>
<body>

<%
const isCoreProgram = query.program_code && query.program_code.endsWith('_CORE');
const schemesDataEJS = {
    "4+0": { cred: 4, th: 4, pr: 0, int: "30+0=30", end: "70+0=70", max: 100, dur: "3 Hours" },
    "0+4": { cred: 4, th: 0, pr: 4, int: "0+30=30", end: "0+70=70", max: 100, dur: "4 Hours" },
    "3+1": { cred: 4, th: 3, pr: 1, int: "20+10=30", end: "50+20=70", max: 100, dur: "3 Hours (Theory), 3 Hours (Practical)" },
    "2+2": { cred: 4, th: 2, pr: 2, int: "15+15=30", end: "35+35=70", max: 100, dur: "2 Hours (Theory), 3 Hours (Practical)" },
    "3+0": { cred: 3, th: 3, pr: 0, int: "25+0=25", end: "50+0=50", max: 75, dur: "3 Hours" },
    "2+0": { cred: 2, th: 2, pr: 0, int: "15+0=15", end: "35+0=35", max: 50, dur: "2 Hours" },
    "1+1": { cred: 2, th: 1, pr: 1, int: "10+5=15", end: "20+15=35", max: 50, dur: "2 Hours (Theory), 3 Hours (Practical)" },
    "2+1": { cred: 3, th: 2, pr: 1, int: "15+5=20", end: "35+20=55", max: 75, dur: "2 Hours (Theory), 3 Hours (Practical)" }
};
%>
<% 
    const electiveGroups = {};
    const linkGroups = {};
    const processedElectiveBases = new Map();
    semesters.forEach(sem => {
        if (sem.courses) {
            sem.courses.forEach((course, index) => {
                if (course.isElective) {
                    const baseElectiveType = course.type.split('.')[0];
                    const exactSemester = String(sem.number);
                    if (!processedElectiveBases.has(baseElectiveType)) {
                        processedElectiveBases.set(baseElectiveType, exactSemester);
                        electiveGroups[baseElectiveType] = { semester: sem, courses: [] };
                    }
                    if (processedElectiveBases.get(baseElectiveType) === exactSemester) {
                        electiveGroups[baseElectiveType].courses.push({ ...course, index });
                    }
                }

                // Group rows that should be linked (e.g., same course type in 4, 4A, 4B)
                const baseSemNum = String(sem.number).replace(/\D/g, '');
                if (baseSemNum) {
                    const linkKey = `${baseSemNum}_${course.type}`;
                    if (!linkGroups[linkKey]) {
                        linkGroups[linkKey] = [];
                    }
                    linkGroups[linkKey].push(`${sem.number}_${index}`);
                }
            })
        }
    })
%>

    <a href="/programs-list" class="back-btn">Back to Programs</a>

    <h2>
        Curriculum Framework: <%= schemeName %> <%= query.program_code ? '- ' + query.program_code : '' %>
        <span id="save-status" style="font-size: 14px; font-weight: normal; color: #28a745; margin-left: 20px; opacity: 0; transition: opacity 0.5s;">Saved!</span>
    </h2>

    <% if (isCoreProgram) { %>
        <div style="background-color: #f8d7da; color: #721c24; padding: 15px; border-radius: 5px; margin-bottom: 20px; border: 1px solid #f5c6cb; font-weight: bold; text-align: center;">
            ⚠️ This is an Auto-Mapped Core Curriculum (Scheme A). Course details and schemes are Read-Only as they are managed via the Multi-Disciplinary Scheme C. You may only edit the Year-End exit options here.
        </div>
    <% } %>

    <div class="guide-box">
        <h3>⚙️ Welcome to the Curriculum Builder! Here is how it works:</h3>
        <ul style="margin: 0; padding-left: 20px; line-height: 1.6; font-size: 14px;">
            <li><strong>Auto-Save:</strong> Automatically saves your changes 1 second after you stop typing. Look for the green "Saved!" text appearing next to the title.</li>
            <li><strong>Course Generation:</strong> Entering a Course Code, Nomenclature, and selecting a Scheme will generate an empty "shell" course. Teachers can then find this course in their list to fill out the detailed syllabus!</li>
            <li><strong>Scheme Overrides:</strong> ⚠️ Changing the scheme of an already saved course will permanently reset it. Doing this will wipe the teacher's data!</li>
            <li><strong>Elective Choices:</strong> The framework automatically provides maximum of 6 rows for any Elective slots so students have choices. Select scheme for the main elective row, then fill the elective table!</li>
            <% if (schemeName && schemeName.includes('Scheme D')) { %>
                <li><strong>Minor Exceptions (Scheme D):</strong> CC-M1, CC-M2, and CC-M3 can be set to fixed courses. If left empty, they will default to "from available pool of Minor/Minor(Vocational)" in the generated syllabus.</li>
            <% } %>
        </ul>
    </div>

    <table id="mainCurriculumTable">
        <thead>
            <tr class="header-row">
                <th style="width: 5%;">Semester</th>
                <th style="width: 10%;">Course Type</th>
                <th style="width: 10%;">Course Code</th>
                <th style="width: 20%;">Nomenclature of the Course</th>
                <th style="width: 8%;">Theory (Th)/ Practical (P)</th>
                <th style="width: 5%;">Credit</th>
                <th>Contact hours per week <br>L(Lecture)+T(Tutorial)+P(Practical)=T(Total)</th>
                <th>Internal Assessment Marks (Th+P=Total)</th>
                <th>End Term Examination Marks (Th+P=Total)</th>
                <th>Total Marks</th>
                <th>Exam Hours Theory, Practical</th>
            </tr>
        </thead>
        <tbody>
            <% semesters.forEach(sem => { %>
                <% if (sem.isDivider) { %> 
                    <% if (sem.title.trim() === '' && Object.keys(electiveGroups).length > 0) { %>
                        <%
                            let hasDecInPrevSem = false;
                            const prevSemIndex = semesters.findIndex(s => s.number === sem.number) - 1;
                            if (prevSemIndex >= 0) { 
                                const prevSem = semesters[prevSemIndex];
                                if (prevSem && prevSem.courses) hasDecInPrevSem = prevSem.courses.some(c => c.isElective);
                            }
                        %>
                        <% if (!hasDecInPrevSem) { %>
                            <tr class="divider-row" style="background-color: <%= sem.color || '#fff3cd' %>; text-align: center; font-weight: bold;"><td colspan="11" style="padding: 10px; font-size: 16px; letter-spacing: 2px;"><%= sem.title %></td></tr>
                        <% } %>
                    <% } else { %>
                    <tr class="divider-row" style="background-color: <%= sem.color || '#fff3cd' %>; text-align: center; font-weight: bold;">
                        <td colspan="11" style="padding: 10px; font-size: 16px; letter-spacing: 2px;">
                            <%= sem.title %>
                        </td>
                    </tr>
                    <% } %>
                <% } else if (sem.isYearlyDivider) { %>
                    <%
                      let defaultExit = "";
                      if (sem.year === 1) defaultExit = "UG Certificate in _______  (MAJOR SUBJECT)  of  _____  Credits will be Awarded in Case of Exit (after 2nd Semester) after completing Internship (4-6 weeks) of 4 Credits";
                      else if (sem.year === 2) defaultExit = "UG Diploma in _______ (MAJOR SUBJECT)  of  _____  Credits will be Awarded in Case of Exit (after 4th Semester) after completing Internship (4-6 weeks) of 4 Credits";
                      else if (sem.year === 3) defaultExit = "Bachelor of _______  with Major in _______  of  _____  Credits will be Awarded in Case of Exit (after 6th Semester)";
                      else if (sem.year === 4) defaultExit = "Bachelor of _______ (Hons.) / (Hons. with Research) in Major  _______  of  _____  Credits will be Awarded (after 8th Semester)";
                      let currentVal = draftData['yearly_divider_' + sem.year];
                      if (currentVal === undefined && defaultExit) currentVal = defaultExit;
                      else if (!currentVal) currentVal = '';
                    %>
                    <tr class="divider-row" style="background-color: <%= sem.color || '#d1ecf1' %>; text-align: center; font-weight: bold;">
                        <td colspan="11" style="padding: 10px;">
                            <input type="text" id="yearly_divider_<%= sem.year %>" value="<%= currentVal %>" placeholder="Enter details/exit option for end of Year <%= sem.year %> (Optional)" style="width: 80%; padding: 8px; text-align: center; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;" oninput="debounceSaveDraft()">
                        </td>
                    </tr>
                <% } else { %>
                    <% 
                       const renderedCoursesCount = sem.courses.filter(c => !c.isElective || c.electiveOpt === 1).length;
                       const rowspanCount = renderedCoursesCount + 1; 
                       let isFirstRenderedRow = true;
                    %>
                    <% sem.courses.forEach((course, index) => { %>
                        <% if (course.isElective) { %>
                            <% if (course.electiveOpt === 1) { %>
                                <% const baseElectiveType = course.type.split('.')[0]; %>
                                <% const choices = electiveGroups[baseElectiveType] ? electiveGroups[baseElectiveType].courses : []; %>
                                <% const cellKey = sem.number + '_' + index; %>
                                <% const summaryDraft = draftData[cellKey + '_summary'] || {}; %>
                                <% const cellDraft = draftData[cellKey] || {}; %>
                                <% const savedCourse = cellDraft.code ? savedCoursesMap[cellDraft.code] : null; %>
                                <% const isSaved = !!savedCourse; %>
                                <tr style="background-color: <%= isSaved ? '#d4edda' : sem.color %>;" data-cell-key="<%= cellKey %>" class="elective-summary-row">
                                    <% if (isFirstRenderedRow) { %>
                                        <td rowspan="<%= rowspanCount %>" class="center" style="background-color: <%= sem.color %>;"><strong><%= sem.number %></strong></td>
                                        <% isFirstRenderedRow = false; %>
                                    <% } %>
                                    <td><span style="color: #0056b3; font-weight: bold;" id="type_<%= cellKey %>" data-type="<%= baseElectiveType %>" data-credits="<%= course.credits %>"><%= baseElectiveType %></span><br><span style="font-size:11px; font-style:italic;">(pick any)</span></td>
                                    <td id="code_<%= cellKey %>" class="elective-code-summary" data-base-type="<%= baseElectiveType %>"></td>
                                    <td><input type="text" value="Any One from the Choices Given Below" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; background-color: transparent; text-align: left; font-style: italic;"></td>
                                    <td class="center" id="td_tp_<%= cellKey %>" style="vertical-align: middle;">
                                        <% const currentScheme = summaryDraft.credit_scheme || ''; %>
                                        <% const displayCredits = course.credits; %>
                                        <select id="scheme_<%= cellKey %>" onchange="handleSchemeChange(this, '<%= cellKey %>')" style="width: 100%; border: 1px solid #ccc; padding: 4px; box-sizing: border-box; background-color: <%= isCoreProgram ? '#e9ecef' : 'transparent' %>;" <%= isCoreProgram ? 'disabled' : '' %>>
                                            <option value="">Scheme</option>
                                            <% if (displayCredits == 4) { %>
                                                <option value="4+0" <%= currentScheme === '4+0' ? 'selected' : '' %>>4+0</option>
                                                <option value="0+4" <%= currentScheme === '0+4' ? 'selected' : '' %>>0+4</option>
                                                <option value="3+1" <%= currentScheme === '3+1' ? 'selected' : '' %>>3+1</option>
                                                <option value="2+2" <%= currentScheme === '2+2' ? 'selected' : '' %>>2+2</option>
                                            <% } else if (displayCredits == 3) { %>
                                                <option value="3+0" <%= currentScheme === '3+0' ? 'selected' : '' %>>3+0</option>
                                                <option value="2+1" <%= currentScheme === '2+1' ? 'selected' : '' %>>2+1</option>
                                            <% } else if (displayCredits == 2) { %>
                                                <option value="2+0" <%= currentScheme === '2+0' ? 'selected' : '' %>>2+0</option>
                                                <option value="1+1" <%= currentScheme === '1+1' ? 'selected' : '' %>>1+1</option>
                                            <% } %>
                                        </select>
                                    </td>
                                    <%
                                        let displayCred = summaryDraft.credits || course.credits;
                                        let displayInt = ''; let displayEnd = ''; let displayMax = ''; let displayDur = '';
                                        if (currentScheme && schemesDataEJS[currentScheme]) {
                                            displayInt = schemesDataEJS[currentScheme].int;
                                            displayEnd = schemesDataEJS[currentScheme].end;
                                            displayMax = schemesDataEJS[currentScheme].max;
                                            displayDur = schemesDataEJS[currentScheme].dur;
                                        }
                                    %>
                                    <td class="center" id="td_cred_<%= cellKey %>" style="vertical-align: middle;"><%= displayCred %></td>
                                    <td class="center" id="td_hrs_<%= cellKey %>" style="vertical-align: middle;">
                                        <% if (currentScheme && schemesDataEJS[currentScheme]) { %>
                                            <script>
                                                // Defer rendering so the DOM element exists
                                                document.addEventListener('DOMContentLoaded', () => {
                                                    renderHrsCell('<%= cellKey %>', <%= schemesDataEJS[currentScheme].th %>, <%= schemesDataEJS[currentScheme].pr %>, false, '<%= summaryDraft.lt_split || "0" %>');
                                                });
                                            </script>
                                        <% } %>
                                    </td>
                                    <td class="center" id="td_int_<%= cellKey %>" style="vertical-align: middle;"><%= displayInt %></td>
                                    <td class="center" id="td_end_<%= cellKey %>" style="vertical-align: middle;"><%= displayEnd %></td>
                                    <td class="center" id="td_max_<%= cellKey %>" style="vertical-align: middle;"><%= displayMax %></td>
                                    <td class="center" id="td_dur_<%= cellKey %>" style="vertical-align: middle;"><%= displayDur %></td>
                                </tr>
                            <% } %>
                            <% // Do not render elective choices (electiveOpt > 1) in the main table %>
                        <% } else { %>

                            <% const cellKey = sem.number + '_' + index; %>
                            <% let cellDraft = draftData[cellKey] || {}; %>
                            <% let savedCourse = cellDraft.code ? savedCoursesMap[cellDraft.code] : null; %>
                            <% let isCommonPgCourse = false; %>
                            <% if (locals.programLevel === 'PG' && locals.commonCoursesMap && locals.commonCoursesMap[course.type]) {
                                isCommonPgCourse = true;
                                const commonData = locals.commonCoursesMap[course.type];
                                savedCourse = commonData;
                                cellDraft = {
                                    code: commonData.course_code,
                                    nom: commonData.course_name,
                                    credit_scheme: commonData.credit_scheme,
                                    credits: commonData.credits_total,
                                    tp: '', hrs: '', int: '', end: '', max: '', dur: ''
                                };
                            } %>
                            <% const isSaved = !!savedCourse; %>
                            <% const isPoolType1 = /^(MDC|AEC|SEC|VAC)/.test(course.type); %>
                            <% const isExceptionMinor = schemeName && schemeName.includes('Scheme D') && /^(CC-M1|CC-M2|CC-M3)$/.test(course.type); %>
                            <% const isPoolType2 = /^(CC-M|CC-HM)/.test(course.type) && !isExceptionMinor; %>
                            <% const isCustomRow = /^(Internship|Intership)$/i.test(course.type); %>
                            <% const isSeminarRow = /^SEMINAR$/i.test(course.type); %>
                            <% const isDissertationRow = /^(PROJECT(?:\s*WORK)?\/DISSERTATION|DISSERTATION)$/i.test(course.type); %>
                            <tr class="<%= isCommonPgCourse ? 'common-pg-row' : '' %>" style="background-color: <%= isSaved && !isPoolType1 && !isPoolType2 && !isCustomRow && !isSeminarRow && !isDissertationRow ? '#d4edda' : sem.color %>;">
                                <% if (isFirstRenderedRow) { %>
                                    <td rowspan="<%= rowspanCount %>" class="center" style="background-color: <%= sem.color %>;">
                                        <strong><%= sem.number %></strong>
                                    </td>
                                    <% isFirstRenderedRow = false; %>
                                <% } %>
                                
                                <% if (isPoolType1) { %>
                                    <td>
                                        <span style="color: #0056b3; font-weight: bold;" id="type_<%= cellKey %>" data-type="<%= course.type %>"><%= course.type %></span>
                                    </td>
                                <td colspan="2" class="center" style="font-style: italic; color: #555;">from available pool of <%= (course.type).slice(0, -2)%></td>
                                <td></td>
                                <td class="center"><%= course.credits %></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                            <% } else if (isPoolType2) { %>
                                <td>
                                    <span style="color: #0056b3; font-weight: bold;" id="type_<%= cellKey %>" data-type="<%= course.type %>"><%= course.type %></span>
                                </td>
                                <td colspan="2" class="center" style="font-style: italic; color: #555;">from available pool of Minor/Minor(Vocational)</td>
                                <td></td>
                                <td class="center"><%= course.credits %></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                            <% } else if (isCustomRow) { %>
                                <td>
                                    <span style="color: #6f42c1; font-weight: bold;" id="type_<%= cellKey %>" data-type="<%= course.type %>"><%= course.type %></span>
                                </td>
                                <td><input type="text" id="code_<%= cellKey %>" placeholder="Code (Opt)" value="<%= cellDraft.code || '' %>" style="width: 100%; border: 1px solid #ccc; padding: 4px; box-sizing: border-box; text-align: center; background-color: <%= isCoreProgram ? '#e9ecef' : 'transparent' %>;" oninput="debounceSaveDraft()" <%= isCoreProgram ? 'readonly' : '' %>></td>
                                <td><input type="text" id="nom_<%= cellKey %>" value="*Internship" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; background-color: transparent; text-align: left; font-weight: bold;"></td>
                                <td class="center"><input type="text" id="tp_<%= cellKey %>" value="" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="cred_<%= cellKey %>" value="" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="hrs_<%= cellKey %>" value="" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="int_<%= cellKey %>" value="" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="end_<%= cellKey %>" value="" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="max_<%= cellKey %>" value="100" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="dur_<%= cellKey %>" value="" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                            <% } else if (isSeminarRow) { %>
                                <td>
                                    <span style="color: #6f42c1; font-weight: bold;" id="type_<%= cellKey %>" data-type="<%= course.type %>"><%= course.type %></span>
                                </td>
                                <td><input type="text" id="code_<%= cellKey %>" placeholder="Code (Opt)" value="<%= cellDraft.code || '' %>" style="width: 100%; border: 1px solid #ccc; padding: 4px; box-sizing: border-box; text-align: center; background-color: <%= isCoreProgram ? '#e9ecef' : 'transparent' %>;" oninput="debounceSaveDraft()" <%= isCoreProgram ? 'readonly' : '' %>></td> 
                                <td><input type="text" id="nom_<%= cellKey %>" value="Seminar" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; background-color: transparent; text-align: left; font-weight: bold;"></td> 
                                <td class="center"><input type="text" id="tp_<%= cellKey %>" value="2T / 0P" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="cred_<%= cellKey %>" value="2" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="hrs_<%= cellKey %>" value="2+0+0=2" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="int_<%= cellKey %>" value="0" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="end_<%= cellKey %>" value="50" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="max_<%= cellKey %>" value="50" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="dur_<%= cellKey %>" value="2 Hours" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                            <% } else if (isDissertationRow) { %>
                                <td>
                                    <span style="color: #6f42c1; font-weight: bold;" id="type_<%= cellKey %>" data-type="<%= course.type %>"><%= course.type %></span>
                                </td>
                                <td><input type="text" id="code_<%= cellKey %>" placeholder="Code (Opt)" value="<%= cellDraft.code || '' %>" style="width: 100%; border: 1px solid #ccc; padding: 4px; box-sizing: border-box; text-align: center; background-color: <%= isCoreProgram ? '#e9ecef' : 'transparent' %>;" oninput="debounceSaveDraft()" <%= isCoreProgram ? 'readonly' : '' %>></td> 
                                <td><input type="text" id="nom_<%= cellKey %>" value="Dissertation" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; background-color: transparent; text-align: left; font-weight: bold;"></td> 
                                <td class="center"><input type="text" id="tp_<%= cellKey %>" value="0T / 12P" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="cred_<%= cellKey %>" value="12" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="hrs_<%= cellKey %>" value="0+0+24=24" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="int_<%= cellKey %>" value="0" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="end_<%= cellKey %>" value="300" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="max_<%= cellKey %>" value="300" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                                <td class="center"><input type="text" id="dur_<%= cellKey %>" value="0 Hours" readonly style="width: 100%; border: none; padding: 4px; box-sizing: border-box; text-align: center; background-color: transparent;"></td>
                            <% } else { %>
                                <td>
                                    <span style="color: <%= isSaved ? '#155724' : '#0056b3' %>; font-weight: bold;" id="type_<%= cellKey %>" data-type="<%= course.type %>"><%= course.type %> <%= isSaved ? '✅' : '' %></span>
                                    <% if (course.type === 'OEC' || course.type === 'MDC') { %><br><span style="font-size:11px; font-style:italic;">(*offered for other depts)</span><% } %>
                                </td>
                                <td>
                                    <input type="text" id="code_<%= cellKey %>" data-type="<%= course.type %>" data-credits="<%= course.credits %>" placeholder="Code" value="<%= cellDraft.code || '' %>" style="width: 100%; border: none; background: <%= isCoreProgram || isCommonPgCourse ? '#e9ecef' : 'transparent' %>; text-align: center; outline: 1px solid #ccc;" onchange="checkCourseCode(this, '<%= cellKey %>', '<%= course.credits %>', '<%= sem.number %>', '<%= sem.color %>')" <%= isCoreProgram || isCommonPgCourse ? 'readonly' : '' %>>
                                </td> 
                                <td><input type="text" id="nom_<%= cellKey %>" placeholder="Enter Nomenclature" value="<%= savedCourse ? savedCourse.course_name : (cellDraft.nom || '') %>" style="width: 100%; border: 1px solid #ccc; padding: 4px; box-sizing: border-box; background-color: <%= isSaved || isCoreProgram || isCommonPgCourse ? '#e9ecef' : 'transparent' %>;" oninput="debounceSaveDraft()" <%= isSaved || isCoreProgram || isCommonPgCourse ? 'readonly' : '' %>></td> 
                                <td class="center" id="td_tp_<%= cellKey %>" style="vertical-align: middle;">
                                        <% const currentScheme = (savedCourse && savedCourse.credit_scheme) || cellDraft.credit_scheme || ''; %>
                                        <% const displayCredits = cellDraft.credits || course.credits; %>
                                        <select id="scheme_<%= cellKey %>" data-dbscheme="<%= savedCourse ? savedCourse.credit_scheme || '' : '' %>" onchange="handleSchemeChange(this, '<%= cellKey %>')" style="width: 100%; border: 1px solid #ccc; padding: 4px; box-sizing: border-box; background-color: <%= isSaved || isCoreProgram || isCommonPgCourse ? '#e9ecef' : 'transparent' %>;" <%= isCoreProgram || isCommonPgCourse ? 'disabled' : '' %>>
                                            <option value="">Scheme</option>
                                            <% if (displayCredits == 4) { %>
                                                <option value="4+0" <%= currentScheme === '4+0' ? 'selected' : '' %>>4+0</option>
                                                <option value="0+4" <%= currentScheme === '0+4' ? 'selected' : '' %>>0+4</option>
                                                <option value="3+1" <%= currentScheme === '3+1' ? 'selected' : '' %>>3+1</option>
                                                <option value="2+2" <%= currentScheme === '2+2' ? 'selected' : '' %>>2+2</option>
                                            <% } else if (displayCredits == 3) { %>
                                                <option value="3+0" <%= currentScheme === '3+0' ? 'selected' : '' %>>3+0</option>
                                                <option value="2+1" <%= currentScheme === '2+1' ? 'selected' : '' %>>2+1</option>
                                            <% } else if (displayCredits == 2) { %>
                                                <option value="2+0" <%= currentScheme === '2+0' ? 'selected' : '' %>>2+0</option>
                                                <option value="1+1" <%= currentScheme === '1+1' ? 'selected' : '' %>>1+1</option>
                                            <% } %>
                                        </select>
                                    </td>
                                    <%
                                        let displayCred = savedCourse ? (savedCourse.credits_total || 0) : displayCredits;
                                        let displayInt = savedCourse && savedCourse.marks_max ? `${savedCourse.marks_internal_theory || 0}+${savedCourse.marks_internal_practical || 0}=${savedCourse.marks_internal_total || 0}` : '';
                                        let displayEnd = savedCourse && savedCourse.marks_max ? `${savedCourse.marks_endterm_theory || 0}+${savedCourse.marks_endterm_practical || 0}=${savedCourse.marks_endterm_total || 0}` : '';
                                        let displayMax = savedCourse ? savedCourse.marks_max : '';
                                        let displayDur = savedCourse ? savedCourse.exam_duration : '';
                                        
                                        // If it's a shell course (max marks are 0 or null) but a scheme is defined, populate from scheme
                                        if ((!displayMax || displayMax == 0) && currentScheme && schemesDataEJS[currentScheme]) {
                                            displayCred = schemesDataEJS[currentScheme].cred;
                                            displayInt = schemesDataEJS[currentScheme].int;
                                            displayEnd = schemesDataEJS[currentScheme].end;
                                            displayMax = schemesDataEJS[currentScheme].max;
                                            displayDur = schemesDataEJS[currentScheme].dur;
                                        }
                                    %>
                                    <td class="center" id="td_cred_<%= cellKey %>" style="vertical-align: middle;"><%= displayCred %></td>
                                    <td class="center" id="td_hrs_<%= cellKey %>" style="vertical-align: middle;">
                                        <% 
                                            let th = 0, pr = 0, hasCreds = false;
                                            if (isSaved && savedCourse && (savedCourse.credits_theory > 0 || savedCourse.credits_practical > 0)) {
                                                th = parseInt(savedCourse.credits_theory) || 0;
                                                pr = parseInt(savedCourse.credits_practical) || 0;
                                                hasCreds = true;
                                            } else if (currentScheme) {
                                                let parts = currentScheme.split('+');
                                                if(parts.length === 2) {
                                                    th = parseInt(parts[0]);
                                                    pr = parseInt(parts[1]);
                                                    hasCreds = true;
                                                }
                                            }
                                            if (hasCreds) {
                                                let lt_split = cellDraft.lt_split || "0";
                                                let p = pr * 2;
                                                let tot = th + p;
                                                if (th > 1) {
                                                    %>
                                                    <select id="ltsplit_<%= cellKey %>" onchange="debounceSaveDraft()" style="background-color: <%= isSaved || isCoreProgram || isCommonPgCourse ? '#e9ecef' : 'transparent' %>; border: 1px solid #ccc; padding: 2px;" <%= isCoreProgram || isCommonPgCourse ? 'disabled' : '' %>>
                                                        <option value="0" <%= lt_split === "0" ? "selected" : "" %>><%= th %>+0+<%= p %>=<%= tot %></option>
                                                        <option value="1" <%= lt_split === "1" ? "selected" : "" %>><%= th-1 %>+1+<%= p %>=<%= tot %></option>
                                                    </select>
                                                    <%
                                                } else {
                                                    %>
                                                    <span id="ltsplit_val_<%= cellKey %>"><%= th %>+0+<%= p %>=<%= tot %></span>
                                                    <%
                                                }
                                            }
                                        %>
                                    </td>
                                    <td class="center" id="td_int_<%= cellKey %>" style="vertical-align: middle;"><%= displayInt || '' %></td>
                                    <td class="center" id="td_end_<%= cellKey %>" style="vertical-align: middle;"><%= displayEnd || '' %></td>
                                    <td class="center" id="td_max_<%= cellKey %>" style="vertical-align: middle;"><%= displayMax || '' %></td>
                                    <td class="center" id="td_dur_<%= cellKey %>" style="vertical-align: middle;"><%= displayDur || '' %></td>
                            <% } %>
                            </tr>
                    <% } %>
                    <% }) %>
                    <tr style="background-color: <%= sem.color %>;" class="total-row">
                        <td>Total</td>
                        <td></td> <td></td> <td></td>
                        <td class="center"><%= sem.totalCredits %></td>
                        <td></td> <td></td> <td></td> <td></td> <td></td>
                    </tr>
                <% } %>
            <% }) %>
        </tbody>
    </table>

    <% if (Object.keys(electiveGroups).length > 0) { %>
        <h2 style="margin-top: 50px;">Elective Choices</h2>
        <p style="text-align: center; font-style: italic; color: #666; margin-top: -10px; margin-bottom: 20px;">Note: A minimum of 2 courses should be provided per elective table.</p>
        <% for (const baseElectiveType in electiveGroups) { %>
            <% const group = electiveGroups[baseElectiveType]; %>
            <h3 style="text-align: left; border: none; margin-top: 30px;">Choices for: <%= baseElectiveType %></h3>
            <table>
                <thead>
                    <tr class="header-row" style="background-color: #f2f2f2;">
                        <th style="width: 15%;">Course Type</th>
                        <th style="width: 25%;">Course Code</th>
                        <th style="width: 60%;">Nomenclature of the Course</th>
                    </tr>
                </thead>
                <tbody>
                    <% group.courses.forEach(course => { %>
                        <% const cellKey = group.semester.number + '_' + course.index; %>
                        <% const cellDraft = draftData[cellKey] || {}; %>
                        <% const savedCourse = cellDraft.code ? savedCoursesMap[cellDraft.code] : null; %>
                        <% const isSaved = !!savedCourse; %>
                        <tr style="background-color: <%= isSaved ? '#d4edda' : group.semester.color %>;" data-base-type="<%= baseElectiveType %>">
                            <td><span style="color: <%= isSaved ? '#155724' : '#0056b3' %>; font-weight: bold;" id="type_<%= cellKey %>" data-type="<%= course.type %>"><%= course.type %> <%= isSaved ? '✅' : '' %></span></td>
                            <td><input type="text" id="code_<%= cellKey %>" data-type="<%= course.type %>" data-credits="<%= course.credits %>" placeholder="Code" value="<%= cellDraft.code || '' %>" style="width: 100%; border: none; background: transparent; text-align: center; outline: 1px solid #ccc;" onchange="checkCourseCode(this, '<%= cellKey %>', '<%= course.credits %>', '<%= group.semester.number %>', '<%= group.semester.color %>')"></td>
                            <td><input type="text" id="nom_<%= cellKey %>" placeholder="Enter Nomenclature" value="<%= savedCourse ? savedCourse.course_name : (cellDraft.nom || '') %>" style="width: 100%; border: 1px solid #ccc; padding: 4px; box-sizing: border-box; background-color: <%= isSaved ? '#e9ecef' : 'transparent' %>;" oninput="debounceSaveDraft()" <%= isSaved ? 'readonly' : '' %>></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    <% } %>

    <script>
        const linkGroups = <%- JSON.stringify(linkGroups) %>;
        const draftData = <%- JSON.stringify(draftData) %>;
        const schemesData = {
            "4+0": { cred: 4, th: 4, pr: 0, int: "30+0=30", end: "70+0=70", max: 100, dur: "3 Hours" },
            "0+4": { cred: 4, th: 0, pr: 4, int: "0+30=30", end: "0+70=70", max: 100, dur: "4 Hours" },
            "3+1": { cred: 4, th: 3, pr: 1, int: "20+10=30", end: "50+20=70", max: 100, dur: "3 Hours (Theory), 3 Hours (Practical)" },
            "2+2": { cred: 4, th: 2, pr: 2, int: "15+15=30", end: "35+35=70", max: 100, dur: "2 Hours (Theory), 3 Hours (Practical)" },
            "3+0": { cred: 3, th: 3, pr: 0, int: "25+0=25", end: "50+0=50", max: 75, dur: "3 Hours" },
            "2+0": { cred: 2, th: 2, pr: 0, int: "15+0=15", end: "35+0=35", max: 50, dur: "2 Hours" },
            "1+1": { cred: 2, th: 1, pr: 1, int: "10+5=15", end: "20+15=35", max: 50, dur: "2 Hours (Theory), 3 Hours (Practical)" },
            "2+1": { cred: 3, th: 2, pr: 1, int: "15+5=20", end: "35+20=55", max: 75, dur: "2 Hours (Theory), 3 Hours (Practical)" }
        };

        function updateElectiveSummaryCodes() {
            document.querySelectorAll('.elective-code-summary').forEach(summaryCell => {
                const baseType = summaryCell.dataset.baseType;
                const choiceRows = document.querySelectorAll(`tr[data-base-type="${baseType}"]`);
                const codes = [];
                choiceRows.forEach(row => {
                    const codeInput = row.querySelector('input[id^="code_"]');
                    if (codeInput && codeInput.value) codes.push(codeInput.value);
                });
                summaryCell.textContent = codes.join(' / ');
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Initial sync for any pre-loaded linked rows
            for (const key in linkGroups) {
                const group = linkGroups[key];
                if (group.length > 1) {
                    const masterKey = group[0];
                    const masterCodeInput = document.getElementById(`code_${masterKey}`);
                    if (masterCodeInput && masterCodeInput.value) {
                        syncSlaveRows(masterKey);
                    }
                }
            }
            updateElectiveSummaryCodes();
        });

        function getSlaveKeys(masterKey) {
            for (const key in linkGroups) {
                const group = linkGroups[key];
                if (group.length > 1 && group[0] === masterKey) {
                    return group.slice(1);
                }
            }
            return [];
        }

        function syncSlaveRows(masterKey, clear = false) {
            const slaveKeys = getSlaveKeys(masterKey);
            if (slaveKeys.length === 0) return;

            const masterRow = document.querySelector(`tr[data-cell-key="${masterKey}"]`);
            if (!masterRow) return;

            slaveKeys.forEach(slaveKey => {
                const slaveRow = document.querySelector(`tr[data-cell-key="${slaveKey}"]`);
                if (!slaveRow) return;

                const masterInputs = masterRow.querySelectorAll('input[id], select[id]');
                masterInputs.forEach(masterInput => {
                    const slaveInput = slaveRow.querySelector(`[id="${masterInput.id.replace(masterKey, slaveKey)}"]`);
                    if (slaveInput) {
                        slaveInput.value = clear ? '' : masterInput.value;
                        slaveInput.readOnly = !clear;
                        slaveInput.disabled = !clear;
                        slaveInput.style.backgroundColor = clear ? 'transparent' : '#e9ecef';
                        slaveInput.style.cursor = clear ? 'pointer' : 'not-allowed';
                    }
                });
            });
        }

        function renderHrsCell(cellKey, th, pr, isSaved, initialLtSplit = null) {
            const td = document.getElementById('td_hrs_' + cellKey);
            if (th === 0 && pr === 0) {
                td.innerHTML = '';
                return;
            }
            const p = pr * 2;
            const totalHrs = th + p;
            const bg = isSaved ? '#e9ecef' : 'transparent';
            
            const oldSelect = document.getElementById('ltsplit_' + cellKey);
            const oldVal = initialLtSplit !== null ? initialLtSplit : (oldSelect ? oldSelect.value : "0");

            if (th > 1) {
                td.innerHTML = `
                    <select id="ltsplit_${cellKey}" onchange="debounceSaveDraft()" style="background-color: ${bg}; border: 1px solid #ccc; padding: 2px;">
                        <option value="0" ${oldVal === "0" ? "selected" : ""}>${th}+0+${p}=${totalHrs}</option>
                        <option value="1" ${oldVal === "1" ? "selected" : ""}>${th-1}+1+${p}=${totalHrs}</option>
                    </select>
                `;
            } else {
                td.innerHTML = `<span id="ltsplit_val_${cellKey}">${th}+0+${p}=${totalHrs}</span>`;
            }
        }

        function updateSchemeValues(cellKey, schemeVal) {
            if (schemeVal && schemesData[schemeVal]) {
                const s = schemesData[schemeVal];
                document.getElementById('td_cred_' + cellKey).innerText = s.cred;
                renderHrsCell(cellKey, s.th, s.pr, false);
                document.getElementById('td_int_' + cellKey).innerText = s.int;
                document.getElementById('td_end_' + cellKey).innerText = s.end;
                document.getElementById('td_max_' + cellKey).innerText = s.max;
                document.getElementById('td_dur_' + cellKey).innerText = s.dur;
            } else {
                document.getElementById('td_hrs_' + cellKey).innerHTML = '';
                ['td_int_', 'td_end_', 'td_max_', 'td_dur_'].forEach(prefix => document.getElementById(prefix + cellKey).innerText = '');
                const codeInput = document.getElementById('code_' + cellKey);
                if (codeInput) {
                    document.getElementById('td_cred_' + cellKey).innerText = codeInput.getAttribute('data-credits');
                }
            }
        }

        async function handleSchemeChange(selectEl, cellKey) {
            const newScheme = selectEl.value;
            const dbScheme = selectEl.getAttribute('data-dbscheme');
            const summaryRow = document.querySelector(`tr[data-cell-key="${cellKey}"].elective-summary-row`);
            
            if (summaryRow) {
                updateSchemeValues(cellKey, newScheme);
                syncSlaveRows(cellKey);
                debounceSaveDraft();
                return;
            }
            // For electives, the code input is in the choices table, not the summary row
            const codeInput = document.getElementById('code_' + cellKey);
            const courseCode = codeInput ? codeInput.value.trim() : '';

            // If this is an existing DB course, and the scheme is changing
            if (courseCode && newScheme && dbScheme !== newScheme) {
                if (dbScheme && !confirm(`WARNING: Changing the credit scheme for ${courseCode} will completely DELETE the existing course and recreate it as an empty shell. All teacher data (Units, CLOs, Mappings) will be permanently lost!\n\nAre you sure you want to proceed?`)) {
                    // Revert selection and cancel
                    selectEl.value = dbScheme;
                    return;
                }

                try {
                    const row = selectEl.closest('tr');
                    const nomInput = row.querySelector('input[id^="nom_"]');
                    const typeSpan = document.getElementById('type_' + cellKey);
                    const urlParams = new URLSearchParams(window.location.search);
                    
                    const codeInputForCredits = document.getElementById('code_' + cellKey);
                    const creditsTotal = codeInputForCredits ? (codeInputForCredits.getAttribute('data-credits') || "0") : "0";

                    const response = await fetch('/reset-course-scheme', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            courseCode, 
                            creditScheme: newScheme, 
                            courseName: nomInput ? nomInput.value.trim() : '', 
                            courseType: typeSpan ? typeSpan.getAttribute('data-type') : '', 
                            creditsTotal: creditsTotal, 
                            programCode: urlParams.get('program_code') 
                        })
                    });
                    const result = await response.json();
                    if (result.success) {
                        selectEl.setAttribute('data-dbscheme', newScheme);
                    } else {
                        alert("Failed to reset course. Please try again.");
                        selectEl.value = dbScheme;
                        return;
                    }
                } catch (err) {
                    console.error("Error resetting course:", err);
                    alert("An error occurred while resetting the course.");
                    selectEl.value = dbScheme;
                    return;
                }
            }

            updateSchemeValues(cellKey, newScheme);
            syncSlaveRows(cellKey);
            debounceSaveDraft();
        }

        async function checkCourseCode(input, cellKey, originalCredits, semester, originalColor) {
            const code = input.value.trim();
            const nomInput = document.getElementById('nom_' + cellKey);
            const typeSpan = document.getElementById('type_' + cellKey);
            const row = input.closest('tr');
            const baseType = row.dataset.baseType;
            const courseType = typeSpan.getAttribute('data-type');

            // Logic to clear the row if code is removed
            if (!code) {
                nomInput.readOnly = false;
                nomInput.style.backgroundColor = 'transparent';
                typeSpan.style.color = '#0056b3';
                typeSpan.innerHTML = courseType;
                row.style.backgroundColor = originalColor; 

                if (baseType) updateElectiveSummaryCodes();
                debounceSaveDraft();
                syncSlaveRows(cellKey, true); // Clear slave rows
                return;
            }

            try {
                const response = await fetch('/api/course/' + encodeURIComponent(code));
                const data = await response.json();
                
                if (data.exists) {
                    console.log("Existing course found! Auto-populating row data.");
                    const c = data.course;
                    nomInput.value = c.course_name;
                    nomInput.readOnly = true;
                    nomInput.style.backgroundColor = '#e9ecef';

                    typeSpan.style.color = '#155724';
                    typeSpan.innerHTML = courseType + ' ✅';
                    row.style.backgroundColor = '#d4edda';

                    if (baseType) updateElectiveSummaryCodes();
                    debounceSaveDraft();
                    syncSlaveRows(cellKey);
                } else {
                    nomInput.readOnly = false;
                    nomInput.style.backgroundColor = 'transparent';
                    typeSpan.style.color = '#0056b3';
                    typeSpan.innerHTML = courseType;
                    row.style.backgroundColor = originalColor;
                    if (baseType) updateElectiveSummaryCodes();
                    debounceSaveDraft();
                }
            } catch (err) {
                console.error("Error checking course code:", err);
                if (baseType) updateElectiveSummaryCodes();
                debounceSaveDraft();
            }
        }

        let saveTimeout;
        function debounceSaveDraft() {
            clearTimeout(saveTimeout);
            // Wait 1 second after typing stops to save
            saveTimeout = setTimeout(saveDraft, 1000);
        }

        async function saveDraft() {
            const urlParams = new URLSearchParams(window.location.search);
            const program_code = urlParams.get('program_code');
            if (!program_code) return;

            const draft_data = Object.fromEntries(Object.entries(draftData).filter(([key, value]) => key.startsWith('yearly_divider_')));
            const rows = document.querySelectorAll('#mainCurriculumTable tbody tr:not(.total-row):not(.divider-row)');
            
            rows.forEach(row => {
                const typeSpan = row.querySelector('span[id^="type_"]');
                const slaveInput = row.querySelector('input[disabled], select[disabled]');
                const isCommonPgRow = row.classList.contains('common-pg-row');

                // If it's a slave row from a linked group, do not save its data.
                if (slaveInput && !isCommonPgRow) {
                    return;
                }
                if (typeSpan) { 
                    const key = typeSpan.id.replace('type_', '');
                    const type = typeSpan.getAttribute('data-type');
                    const isCustomRow = /^(Internship|Intership)$/i.test(type);
                    const isSeminarRow = /^SEMINAR$/i.test(type);
                    const isDissertationRow = /^(PROJECT(?:\s*WORK)?\/DISSERTATION|DISSERTATION)$/i.test(type);

                    if (isCustomRow || isSeminarRow || isDissertationRow) {
                        const code = row.querySelector('#code_' + key) ? row.querySelector('#code_' + key).value.trim() : "";
                        const nom = row.querySelector('#nom_' + key) ? row.querySelector('#nom_' + key).value.trim() : "";
                        const tp = row.querySelector('#tp_' + key) ? row.querySelector('#tp_' + key).value.trim() : "";
                        const credits = row.querySelector('#cred_' + key) ? row.querySelector('#cred_' + key).value.trim() : "";
                        const hrs = row.querySelector('#hrs_' + key) ? row.querySelector('#hrs_' + key).value.trim() : "";
                        const int = row.querySelector('#int_' + key) ? row.querySelector('#int_' + key).value.trim() : "";
                        const end = row.querySelector('#end_' + key) ? row.querySelector('#end_' + key).value.trim() : "";
                        const max = row.querySelector('#max_' + key) ? row.querySelector('#max_' + key).value.trim() : "";
                        const dur = row.querySelector('#dur_' + key) ? row.querySelector('#dur_' + key).value.trim() : "";

                        if (code || nom || tp || credits || hrs || int || end || max || dur) {
                            draft_data[key] = { is_custom_row: true, type, code, nom, tp, credits, hrs, int, end, max, dur };
                        }
                    } else {
                        const codeInput = row.querySelector('#code_' + key);
                        const nomInput = row.querySelector('#nom_' + key);
                        let schemeSelect = row.querySelector('#scheme_' + key);
                        let ltSplitSelect = row.querySelector('#ltsplit_' + key);

                        if (row.classList.contains('elective-summary-row')) {
                            // This is an elective summary row
                            const credit_scheme = schemeSelect ? schemeSelect.value : "";
                            const lt_split = ltSplitSelect ? ltSplitSelect.value : "0";
                            const credits = typeSpan.getAttribute('data-credits') || "0"; // Safely get credits from the DOM
                            draft_data[key + '_summary'] = { type, credits, credit_scheme, lt_split };
                        } else if (codeInput && nomInput) {
                            // This is a normal or choice row
                            const code = codeInput.value.trim();
                            const nom = nomInput.value.trim();
                            const credits = codeInput.getAttribute('data-credits');
                            const credit_scheme = schemeSelect ? schemeSelect.value : "";
                            const lt_split = ltSplitSelect ? ltSplitSelect.value : "0";
                            if (code || nom || credit_scheme) {
                                draft_data[key] = { code, nom, type, credits, credit_scheme, lt_split };
                            }
                        }
                    }
                }
            });
            
            // Re-add logic to save elective choice tables
            const electiveChoiceRows = document.querySelectorAll('tr[data-base-type]');
            electiveChoiceRows.forEach(row => {
                const codeInput = row.querySelector('input[id^="code_"]');
                if (codeInput) {
                    const key = codeInput.id.replace('code_', '');
                    const code = codeInput.value.trim();
                    const nom = row.querySelector('#nom_' + key).value.trim();

                    const baseType = row.dataset.baseType;
                    const summarySpan = document.querySelector(`tr.elective-summary-row span[data-type="${baseType}"]`);
                    let credit_scheme = "";
                    let lt_split = "0";
                    if (summarySpan) {
                        const summaryRow = summarySpan.closest('tr');
                        const schemeSelect = summaryRow.querySelector('select[id^="scheme_"]');
                        const ltSelect = summaryRow.querySelector('select[id^="ltsplit_"]');
                        if (schemeSelect) credit_scheme = schemeSelect.value;
                        if (ltSelect) lt_split = ltSelect.value;
                    }

                    if (code || nom) draft_data[key] = { code, nom, type: codeInput.dataset.type, credits: codeInput.dataset.credits, credit_scheme, lt_split };
                }
            });

            const yearlyDividers = document.querySelectorAll('input[id^="yearly_divider_"]');
            yearlyDividers.forEach(input => {
                if(input.value.trim() !== '') {
                    draft_data[input.id] = input.value.trim();
                }
            });

            try {
                const response = await fetch('/save-curriculum-draft', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ program_code, draft_data })
                });
                
                const result = await response.json();
                if (result.success) {
                    const statusLabel = document.getElementById('save-status');
                    statusLabel.style.opacity = '1';
                    setTimeout(() => statusLabel.style.opacity = '0', 2000);
                }
            } catch (err) {
                console.error("Draft Auto-save failed:", err);
            }
        }
    </script>
</body>
</html>