<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Scheme Main Table</title>
    <style>
        body {
            padding: 20px;
            font-family: Arial, sans-serif;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            margin-bottom: 20px;
        }
        th, td {
            border: 1px solid #888;
            padding: 8px;
            text-align: left;
        }
        .header-row {
            background-color: #e2efda;
            font-weight: bold;
        }
        .total-row {
            font-weight: bold;
        }
        .center { text-align: center; }
        .back-btn {
            display: inline-block;
            margin-bottom: 20px;
            padding: 10px 20px;
            background: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }
        .back-btn:hover {
            background: #5a6268;
        }
    </style>
</head>
<body>

    <a href="/programs-list" class="back-btn">Back to Programs</a>

    <h2>Curriculum Framework: <%= schemeName %> <%= query.program_name ? '- ' + query.program_name : '' %></h2>

    <table>
        <thead>
            <tr class="header-row">
                <th>Semester</th>
                <th>Course Type</th>
                <th>Course Code</th>
                <th>Nomenclature of course</th>
                <th>Theory(T)/ Practical(P)</th>
                <th>Credit</th>
                <th>Contact hours per week</th>
                <th>Internal Assessment Marks</th>
                <th>End Term Examination Marks</th>
                <th>Total Marks</th>
                <th>Exam Hours</th>
            </tr>
        </thead>
        <tbody>
            <% semesters.forEach(sem => { %>
                <% sem.courses.forEach((course, index) => { %>
                    <tr style="background-color: <%= sem.color %>;">
                        <% if (index === 0) { %>
                            <td rowspan="<%= sem.courses.length + 1 %>" class="center">
                                <strong><%= sem.number %></strong>
                            </td>
                        <% } %>
                        <td><%= course.type %></td>
                        <td></td> <td></td> <td></td>
                        <td class="center"><%= course.credits %></td>
                        <td></td> <td></td> <td></td> <td></td> <td></td>
                    </tr>
                <% }) %>
                <tr style="background-color: <%= sem.color %>;" class="total-row">
                    <td>Total</td>
                    <td></td> <td></td> <td></td>
                    <td class="center"><%= sem.totalCredits %></td>
                    <td></td> <td></td> <td></td> <td></td> <td></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>