<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Scheme Main Table</title>
    <style>
        body {
            padding: 20px;
            font-family: Arial, sans-serif;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            margin-bottom: 20px;
        }
        th, td {
            border: 1px solid #888;
            padding: 8px;
            text-align: left;
        }
        .header-row {
            background-color: #e2efda;
            font-weight: bold;
        }
        .total-row {
            font-weight: bold;
        }
        .center { text-align: center; }
        .back-btn {
            display: inline-block;
            margin-bottom: 20px;
            padding: 10px 20px;
            background: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }
        .back-btn:hover {
            background: #5a6268;
        }
    </style>
</head>
<body>

    <a href="/programs-list" class="back-btn">Back to Programs</a>

    <h2>
        Curriculum Framework: <%= schemeName %> <%= query.program_name ? '- ' + query.program_name : '' %>
        <span id="save-status" style="font-size: 14px; font-weight: normal; color: #28a745; margin-left: 20px; opacity: 0; transition: opacity 0.5s;">Saved!</span>
    </h2>

    <table>
        <thead>
            <tr class="header-row">
                <th>Semester</th>
                <th>Course Type</th>
                <th>Course Code</th>
                <th>Nomenclature of course</th>
                <th>Theory(T)/ Practical(P)</th>
                <th>Credit</th>
                <th>Contact hours per week</th>
                <th>Internal Assessment Marks</th>
                <th>End Term Examination Marks</th>
                <th>Total Marks</th>
                <th>Exam Hours</th>
            </tr>
        </thead>
        <tbody>
            <% semesters.forEach(sem => { %>
                <% sem.courses.forEach((course, index) => { %>
                    <% const cellKey = sem.number + '_' + index; %>
                    <% const cellDraft = draftData[cellKey] || {}; %>
                    <% const savedCourse = cellDraft.code ? savedCoursesMap[cellDraft.code] : null; %>
                    <% const isSaved = !!savedCourse; %>
                    <tr style="background-color: <%= isSaved ? '#d4edda' : sem.color %>;">
                        <% if (index === 0) { %>
                            <td rowspan="<%= sem.courses.length + 1 %>" class="center" style="background-color: <%= sem.color %>;">
                                <strong><%= sem.number %></strong>
                            </td>
                        <% } %>
                        <td>
                            <a href="#" style="color: <%= isSaved ? '#155724' : '#0056b3' %>; text-decoration: underline; font-weight: bold;" id="link_<%= cellKey %>" data-type="<%= course.type %>" onclick="openCourseForm(event, this, 'nom_<%= cellKey %>', 'code_<%= cellKey %>', <%= isSaved %>, '<%= sem.number %>')"><%= course.type %> <%= isSaved ? '✅' : '' %></a>
                        </td>
                        <td><input type="text" id="code_<%= cellKey %>" placeholder="Code" value="<%= cellDraft.code || '' %>" style="width: 100%; border: none; background: transparent; text-align: center;" oninput="debounceSaveDraft()" onchange="checkCourseCode(this, '<%= cellKey %>', '<%= course.credits %>', '<%= sem.number %>', '<%= sem.color %>')"></td> 
                        <td><input type="text" id="nom_<%= cellKey %>" placeholder="Enter Nomenclature" value="<%= savedCourse ? savedCourse.course_name : (cellDraft.nom || '') %>" style="width: 100%; border: 1px solid #ccc; padding: 4px; box-sizing: border-box; background-color: <%= isSaved ? '#e9ecef' : 'transparent' %>;" oninput="debounceSaveDraft()" <%= isSaved ? 'readonly' : '' %>></td> 
                        <td class="center" id="td_tp_<%= cellKey %>"><%= savedCourse ? ((savedCourse.credits_theory || 0) + 'T / ' + (savedCourse.credits_practical || 0) + 'P') : '' %></td>
                        <td class="center" id="td_cred_<%= cellKey %>"><%= savedCourse ? (savedCourse.credits_total || 0) : course.credits %></td>
                        <td class="center" id="td_hrs_<%= cellKey %>"><%= savedCourse ? ((savedCourse.credits_theory || 0) + ((savedCourse.credits_practical || 0) * 2)) : '' %></td>
                        <td class="center" id="td_int_<%= cellKey %>"><%= savedCourse ? (savedCourse.marks_internal_total || 0) : '' %></td>
                        <td class="center" id="td_end_<%= cellKey %>"><%= savedCourse ? (savedCourse.marks_endterm_total || 0) : '' %></td>
                        <td class="center" id="td_max_<%= cellKey %>"><%= savedCourse ? (savedCourse.marks_max || 0) : '' %></td>
                        <td class="center" id="td_dur_<%= cellKey %>"><%= savedCourse ? (savedCourse.exam_duration || '') : '' %></td>
                    </tr>
                <% }) %>
                <tr style="background-color: <%= sem.color %>;" class="total-row">
                    <td>Total</td>
                    <td></td> <td></td> <td></td>
                    <td class="center"><%= sem.totalCredits %></td>
                    <td></td> <td></td> <td></td> <td></td> <td></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <script>
        function openCourseForm(event, linkElement, nomId, codeId, isSaved, semester) {
            event.preventDefault();
            const nomenclature = document.getElementById(nomId).value.trim();
            const courseCode = document.getElementById(codeId).value.trim();
            
            if (!courseCode) {
                alert("Please fill the Course Code before opening the course form.");
                return;
            }

            if (!nomenclature) {
                alert("Please fill the Nomenclature of the course before opening the course form.");
                return;
            }
            
            const courseType = linkElement.innerText.replace('✅', '').trim();
            
            // Extract program name from current URL
            const urlParams = new URLSearchParams(window.location.search);
            const programName = urlParams.get('program_name') || '';
            
            if (isSaved && courseCode) {
                window.open(`/edit-course/${encodeURIComponent(courseCode)}`, '_blank');
            } else {
                let url = `/courses?courseName=${encodeURIComponent(nomenclature)}&courseType=${encodeURIComponent(courseType)}`;
                if (courseCode) url += `&courseCode=${encodeURIComponent(courseCode)}`;
                if (programName) url += `&programmeName=${encodeURIComponent(programName)}`;
                if (semester) url += `&semester=${encodeURIComponent(semester)}`;
                
                window.open(url, '_blank');
            }
        }

        async function checkCourseCode(input, cellKey, originalCredits, semester, originalColor) {
            const code = input.value.trim();
            const nomInput = document.getElementById('nom_' + cellKey);
            const link = document.getElementById('link_' + cellKey);
            const row = input.closest('tr');
            const courseType = link.getAttribute('data-type');

            if (!code) {
                nomInput.readOnly = false;
                nomInput.style.backgroundColor = 'transparent';
                link.style.color = '#0056b3';
                link.innerHTML = courseType;
                link.setAttribute('onclick', `openCourseForm(event, this, 'nom_${cellKey}', 'code_${cellKey}', false, '${semester}')`);
                
                ['td_tp_', 'td_hrs_', 'td_int_', 'td_end_', 'td_max_', 'td_dur_'].forEach(prefix => document.getElementById(prefix + cellKey).innerText = '');
                document.getElementById('td_cred_' + cellKey).innerText = originalCredits;
                row.style.backgroundColor = originalColor; 
                return;
            }

            try {
                const response = await fetch('/api/course/' + encodeURIComponent(code));
                const data = await response.json();
                
                if (data.exists) {
                    alert("Existing course found! Auto-populating row data.");
                    const c = data.course;
                    nomInput.value = c.course_name;
                    nomInput.readOnly = true;
                    nomInput.style.backgroundColor = '#e9ecef';
                    
                    document.getElementById('td_tp_' + cellKey).innerText = (c.credits_theory || 0) + 'T / ' + (c.credits_practical || 0) + 'P';
                    document.getElementById('td_cred_' + cellKey).innerText = (c.credits_total || 0);
                    document.getElementById('td_hrs_' + cellKey).innerText = (c.credits_theory || 0) + ((c.credits_practical || 0) * 2);
                    document.getElementById('td_int_' + cellKey).innerText = (c.marks_internal_total || 0);
                    document.getElementById('td_end_' + cellKey).innerText = (c.marks_endterm_total || 0);
                    document.getElementById('td_max_' + cellKey).innerText = (c.marks_max || 0);
                    document.getElementById('td_dur_' + cellKey).innerText = (c.exam_duration || '');
                    
                    link.style.color = '#155724';
                    link.innerHTML = courseType + ' ✅';
                    link.setAttribute('onclick', `openCourseForm(event, this, 'nom_${cellKey}', 'code_${cellKey}', true, '${semester}')`);
                    row.style.backgroundColor = '#d4edda';
                    
                    debounceSaveDraft();
                } else {
                    nomInput.readOnly = false;
                    nomInput.style.backgroundColor = 'transparent';
                    link.style.color = '#0056b3';
                    link.innerHTML = courseType;
                    link.setAttribute('onclick', `openCourseForm(event, this, 'nom_${cellKey}', 'code_${cellKey}', false, '${semester}')`);
                    row.style.backgroundColor = originalColor; 
                }
            } catch (err) {
                console.error("Error checking course code:", err);
            }
        }

        let saveTimeout;
        function debounceSaveDraft() {
            clearTimeout(saveTimeout);
            // Wait 1 second after typing stops to save
            saveTimeout = setTimeout(saveDraft, 1000);
        }

        async function saveDraft() {
            const urlParams = new URLSearchParams(window.location.search);
            const program_name = urlParams.get('program_name');
            const specialization = urlParams.get('specialization');
            if (!program_name || !specialization) return;

            const draft_data = {};
            const rows = document.querySelectorAll('tbody tr:not(.total-row)');
            
            rows.forEach(row => {
                const codeInput = row.querySelector('input[id^="code_"]');
                const nomInput = row.querySelector('input[id^="nom_"]');
                if(codeInput && nomInput) {
                    const key = codeInput.id.replace('code_', '');
                    const code = codeInput.value.trim();
                    const nom = nomInput.value.trim();
                    if (code || nom) draft_data[key] = { code, nom };
                }
            });

            try {
                const response = await fetch('/save-curriculum-draft', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ program_name, specialization, draft_data })
                });
                
                const result = await response.json();
                if (result.success) {
                    const statusLabel = document.getElementById('save-status');
                    statusLabel.style.opacity = '1';
                    setTimeout(() => statusLabel.style.opacity = '0', 2000);
                }
            } catch (err) {
                console.error("Draft Auto-save failed:", err);
            }
        }
    </script>
</body>
</html>