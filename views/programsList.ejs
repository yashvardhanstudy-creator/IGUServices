<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="shortcut icon" href="https://igu1.ucanapply.com/images/webicon.png" type="image/png">
    <meta charset="UTF-8">
    <title>Programs List</title>
    <link rel="stylesheet" href="/stylesheets/index.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            max-width: 900px;
            width: 100%;
        }
        h1 {
            color: #333;
            margin-bottom: 20px;
            text-align: center;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }
        th {
            background-color: #667eea;
            color: white;
        }
        tr:hover {
            background-color: #f1f1f1;
        }
        .btn {
            padding: 8px 12px;
            background: #17a2b8;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            font-size: 14px;
            display: inline-block;
        }
        .btn:hover {
            background: #117a8b;
        }
        .back-btn {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>Existing Programmes & Specializations</h1>
        <% if (locals.query && locals.query.message) { %>
            <div style="color: green; background-color: #e8f5e9; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;"><%= locals.query.message %></div>
        <% } %>
        <div style="text-align: center; margin-bottom: 20px;">
            <a href="/" class="back-btn">Back to Home</a>
            <a href="/feedback" class="btn" style="background-color: #ffc107; color: #000; border: 1px solid #d39e00;">💬 View & Submit Feedback</a>
        </div>
        
        <table>
            <thead>
                <tr>
                    <th>Internal Programme ID</th>
                    <th>Department Name</th>
                    <th>Level</th>
                    <th>Scheme</th>
                    <th>POs/PEOs/PSOs</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% programs.forEach(p => { %>
                    <tr>
                        <td><strong><%= p.program_code %></strong></td>
                        <td><%= p.subject_name %></td>
                        <td><%= p.level %></td>
                        <td>Scheme <%= p.scheme %></td>
                        <td><%= p.num_pos %> / <%= p.num_peos %> / <%= p.num_psos %></td>
                        <td style="white-space: nowrap;">
                            <a class="btn" style="background-color: #28a745; margin-right: 5px;" href="/view-curriculum?program_code=<%= encodeURIComponent(p.program_code) %>">View</a>
                            <% if (locals.isAdmin || (locals.userDept && p.department === locals.userDept)) { %>
                                <a class="btn" href="/curriculum?program_code=<%= encodeURIComponent(p.program_code) %>&scheme=<%= encodeURIComponent(p.scheme) %>">Edit</a>
                                <form action="/delete-program" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this program? Its curriculum draft will also be permanently deleted.');">
                                    <input type="hidden" name="program_code" value="<%= p.program_code %>">
                                    <button type="submit" class="btn" style="background-color: #dc3545; color: white; border: none; cursor: pointer; margin-left: 5px;">Delete</button>
                                </form>
                            <% } else { %>
                                <span style="color: #6c757d; font-style: italic;">🔒 Locked</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>
