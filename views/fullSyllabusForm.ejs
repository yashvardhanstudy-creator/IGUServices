<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Generate Full Syllabus</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; padding: 20px; display: flex; justify-content: center; }
        .container { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1); max-width: 800px; width: 100%; }
        h1 { color: #333; margin-bottom: 20px; text-align: center; }
        ul { list-style-type: none; padding: 0; }
        li { background-color: #f8f9fa; border: 1px solid #e9ecef; padding: 15px; margin-bottom: 10px; border-radius: 5px; display: flex; justify-content: space-between; align-items: center; }
        a.btn { padding: 8px 15px; background: #007bff; color: white; text-decoration: none; border-radius: 5px; }
        a.btn:hover { background: #0056b3; }
        .back-btn { display: inline-block; margin-bottom: 20px; padding: 10px 20px; background: #6c757d; color: white; text-decoration: none; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <a href="/" class="back-btn">← Back to Home</a>
        <h1>Select a Program to Generate Syllabus</h1>
        
        <% if (locals.query && locals.query.error) { %>
            <div style="color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;"><%= locals.query.error %></div>
        <% } %>

        <% if (options.length > 0) { %>
            <ul>
                <% options.forEach(opt => { %>
                    <li>
                        <span>
                            <strong><%= opt.subject_name %></strong> - <%= opt.specialization || 'General' %> (<%= opt.program_code %>)
                        </span>
                        <a href="/program-details-form?program_code=<%= encodeURIComponent(opt.program_code) %>" class="btn">
                            Fill Details & View
                        </a>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p style="text-align: center;">No programs found. Please create a program and a curriculum draft first.</p>
        <% } %>
    </div>
</body>
</html>