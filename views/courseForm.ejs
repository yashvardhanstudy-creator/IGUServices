<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Course Framework Form</title>
    <style>
        body { font-family: 'Times New Roman', serif; line-height: 1.6; color: #333; padding: 20px; }
        .form-container { max-width: 900px; margin: auto; border: 1px solid #000; padding: 30px; }
        h2, h3 { text-align: center; text-transform: uppercase; border-bottom: 2px solid #000; padding-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { border: 1px solid #000; padding: 8px; text-align: left; }
        .header-cell { background-color: #f2f2f2; font-weight: bold; width: 30%; }
        .section-title { background-color: #e9e9e9; font-weight: bold; text-align: center; }
        input[type="text"], input[type="number"], select, textarea {
            width: 100%;
            padding: 6px;
            box-sizing: border-box;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
        input[readonly] {
            background-color: #e9ecef;
            cursor: not-allowed;
            font-weight: bold;
        }
        .form-section { margin-bottom: 30px; }
        .submit-btn {
            display: block;
            width: 200px;
            margin: 40px auto 0;
            padding: 12px;
            font-size: 16px;
            font-weight: bold;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }
        [contenteditable][placeholder]:empty:before {
            content: attr(placeholder);
            color: #999;
            pointer-events: none;
            display: block;
        }
        .guide-box {
            background: #e8f4f8;
            border: 1px solid #b8daff;
            border-radius: 6px;
            padding: 15px 20px;
            margin-bottom: 25px;
            color: #004085;
            font-family: Arial, sans-serif;
        }
        .guide-box h3 {
            margin: 0 0 10px 0; border-bottom: 1px solid #b8daff; padding-bottom: 8px;
            font-size: 16px; text-align: left; text-transform: none; color: #004085;
        }
    </style>
</head>
<body>

<div class="form-container">

<% if (locals.query && locals.query.error) { %>
    <div style="color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;"><%= locals.query.error %></div>
<% } %>

<%
    let isPool = false;
    let deptName = "";
    if (typeof course !== 'undefined') {
        if (!course.owning_program_code || course.owning_program_code === 'From University Pool' || course.owning_program_code.startsWith('POOL')) {
            isPool = true;
            if (course.owning_program_code && course.owning_program_code.startsWith('POOL|')) {
                deptName = course.owning_program_code.substring(5);
            } else if (course.programme_name && course.programme_name !== 'Unassigned') {
                deptName = course.programme_name;
            }
        }
    } else {
        isPool = true; 
    }
%>

<div class="guide-box">
    <h3>📝 Course Editor Guide</h3>
    <ul style="margin: 0; padding-left: 20px; line-height: 1.5; font-size: 14px;">
        <li style="margin-bottom: 6px;"><strong>Course Category:</strong> You are editing a <%= isPool ? 'University Pool' : 'Program-Specific' %> course. <%= isPool ? 'Pool courses allow custom mapping and independent departmental ownership.' : 'PO/PSO mapping is strictly locked to its parent framework.' %></li>
        <li style="margin-bottom: 6px;"><strong>Contact Hours:</strong> Ensure your Unit Contact Hours perfectly sum up to the target hours generated by the selected Credit Scheme (look for the red/black counter at the bottom of the Units table).</li>
        <li><strong>CLOs & Mappings:</strong> Enter Course Learning Outcomes (CLOs) one per line. The PO/PSO mapping table at the bottom of the form will automatically generate and sync based on your entries!</li>
    </ul>
</div>

<form action="/courses" method="POST">
    <input type="hidden" name="isEditMode" value="<%= typeof course !== 'undefined' ? 'true' : 'false' %>">
    <input type="hidden" name="is_pool_course" value="<%= isPool ? 'true' : 'false' %>">
    <div class="form-section">
        <h3>Select Scheme</h3>
        <label for="creditScheme">Credit Scheme (Theory+Practical):</label>
        <% if (typeof course !== 'undefined' && course.credit_scheme) { %>
            <input type="text" value="<%= course.credit_scheme %>" readonly style="background-color: #e9ecef; font-weight: bold; width: 100%; padding: 6px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
            <input type="hidden" id="creditScheme" name="creditScheme" value="<%= course.credit_scheme %>">
            <div style="font-size: 0.8em; color: #666; margin-top: 4px;">Credit Scheme is assigned by the Admin in the Curriculum Framework.</div>
        <% } else { %>
            <select id="creditScheme" name="creditScheme" onchange="autofillForm()" required>
                <option value="">-- Select a Scheme --</option>
                <option value="4+0">4 + 0</option>
                <option value="0+4">0 + 4</option>
                <option value="3+1">3 + 1</option>
                <option value="2+2">2 + 2</option>
                <option value="3+0">3 + 0</option>
                <option value="2+0">2 + 0</option>
                <option value="1+1">1 + 1</option>
                <option value="2+1">2 + 1</option>
            </select>
            <div style="font-size: 0.8em; color: #666; margin-top: 4px;">For University Pool courses, please select the appropriate scheme.</div>
        <% } %>
    </div>

    <div class="form-section">
        <h2>Part A - Introduction</h2>
        <table>
            <tr>
                <td class="header-cell" id="prog_dept_label"><%= isPool ? 'Department Name' : 'Name of the Programme/Subject' %></td>
                <td colspan="3">
                    <input type="text" id="owning_program" name="owning_program" value="<%= isPool ? deptName : (typeof course !== 'undefined' && course.programme_name ? course.programme_name : '') %>" <%= isPool ? 'placeholder="e.g. Department of Mathematics"' : 'readonly style="background-color: #e9ecef;"' %>>
                    <input type="hidden" name="owning_program_code" id="owning_program_code" value="<%= typeof course !== 'undefined' ? (course.owning_program_code || '') : (locals.query && locals.query.programCode ? locals.query.programCode : '') %>">
                </td>
            </tr>
            <tr>
                <td class="header-cell">Semester</td>
                <td colspan="3"><input type="text" name="semester" value="<%= typeof course !== 'undefined' ? course.semester : (query.semester || '') %>" required <%= isPool ? 'placeholder="e.g. 1st, 2nd, 3rd"' : 'readonly style="background-color: #e9ecef;"' %>></td>
            </tr>
            <tr>
                <td class="header-cell">Nature of Course</td>
                <td colspan="3"><input type="text" name="natureOfCourse" id="natureOfCourse" required readonly></td>
            </tr>
            <tr>
                <td class="header-cell">Name of the Course</td>
                <td colspan="3"><input type="text" name="courseName" value="<%= query.courseName || '' %>" required></td>
            </tr>
            <tr>
                <td class="header-cell">Course Code</td>
                <td><input type="text" name="courseCode" value="<%= query.courseCode || '' %>" required></td>
                <td class="header-cell">Course Type</td>
                <td>
                    <input type="text" name="courseType" value="<%= query.courseType || '' %>" placeholder="e.g. Core (Optional for Pool)">
                    <div style="font-size: 0.8em; color: #666; margin-top: 4px; line-height: 1.2;">Will be automatically overridden by the Curriculum slot if placed in a different program.</div>
                </td>
            </tr>
            <tr>
                <td class="header-cell">Pre-requisite for the course (if any)</td>
                <td colspan="3"><input type="text" name="prerequisite"></td>
            </tr>
            <tr>
                <td class="header-cell">Course Learning Outcomes (CLO)</td>
                <td colspan="3"><textarea id="clos" name="courseOutcomes" rows="4" placeholder="Enter each CLO on a new line (Minimum 2, Maximum 6)." oninput="generateMappingTable()"></textarea></td>
            </tr>
        </table>

        <h3>Credit and Marks Distribution</h3>
        <table>
            <tr class="section-title">
                <td>Category</td>
                <td>Theory</td>
                <td>Practical</td>
                <td>Total</td>
            </tr>
            <tr>
                <td class="header-cell">Credits</td>
                <td><input type="text" id="credits_theory" name="credits_theory" readonly></td>
                <td><input type="text" id="credits_practical" name="credits_practical" readonly></td>
                <td><input type="text" id="credits_total" name="credits_total" readonly></td>
            </tr>
            <tr>
                <td class="header-cell">Teaching Hours per week</td>
                <td><input type="text" id="hours_theory" name="hours_theory" readonly></td>
                <td><input type="text" id="hours_practical" name="hours_practical" readonly></td>
                <td><input type="text" id="hours_total" name="hours_total" readonly></td>
            </tr>
            <tr>
                <td class="header-cell">Total Contact Hours (per semester)</td>
                <td><input type="text" id="contact_hours_theory" name="contact_hours_theory" readonly></td>
                <td><input type="text" id="contact_hours_practical" name="contact_hours_practical" readonly></td>
                <td><input type="text" id="contact_hours_total" name="contact_hours_total" readonly></td>
            </tr>
            <tr>
                <td class="header-cell">Internal Assessment</td>
                <td><input type="text" id="marks_internal_theory" name="marks_internal_theory" readonly></td>
                <td><input type="text" id="marks_internal_practical" name="marks_internal_practical" readonly></td>
                <td><input type="text" id="marks_internal_total" name="marks_internal_total" readonly></td>
            </tr>
            <tr>
                <td class="header-cell">End Term Exam</td>
                <td><input type="text" id="marks_endterm_theory" name="marks_endterm_theory" readonly></td>
                <td><input type="text" id="marks_endterm_practical" name="marks_endterm_practical" readonly></td>
                <td><input type="text" id="marks_endterm_total" name="marks_endterm_total" readonly></td>
            </tr>
            <tr>
                <td class="header-cell">Max Marks</td>
                <td colspan="2" style="text-align: center;">Total Max Marks</td>
                <td><input type="text" id="marks_max" name="marks_max" readonly></td>
            </tr>
            <tr>
                <td class="header-cell">Examination Duration</td>
                <td colspan="3"><input type="text" id="exam_duration" name="exam_duration" readonly></td>
            </tr>
        </table>
    </div>

    <div class="form-section">
        <h2>Part B - Contents of the Course</h2>
        <div id="important-notes" style="display: flex; gap: 20px;">
            <div id="theory_container" style="flex: 1; display: none;">
                <label>Theory Instructions</label>
                <div id="instructions_theory" style="border: 1px solid #ccc; padding: 10px; background-color: #e9ecef; border-radius: 4px; min-height: 100px;"></div>
            </div>
            <div id="practical_container" style="flex: 1; display: none;">
                <label>Practical Instructions</label>
                <div id="instructions_practical" style="border: 1px solid #ccc; padding: 10px; background-color: #e9ecef; border-radius: 4px; min-height: 100px;"></div>
            </div>
            <input type="hidden" name="paperSetterInstructions" id="paperSetterInstructions">
        </div>

        <h3>Syllabus Units</h3>
        <table>
            <thead>
                <tr class="section-title">
                    <td>Unit</td>
                    <td>Topics</td>
                <td style="width: 15%;">CLOs</td>
                <td style="width: 15%;">Contact Hours</td>
                </tr>
            </thead>
            <tbody id="unitsContainer">
                <!-- Units will be generated here by JS -->
            </tbody>
            <tfoot id="unitsFooter" style="font-weight: bold;">
                <!-- Totals will be generated here by JS -->
            </tfoot>
        </table>

        <h3>Suggested Evaluation Methods</h3>
        <table>
            <tr class="section-title">
                <td>Internal Assessment: 30</td>
                <td id="eval_internal_th_total">TH-</td>
                <td id="eval_internal_pr_total">PR-</td>
                <td id="eval_endterm_total">End Term Examination: </td>
                <td id="eval_endterm_th_total">TH-</td>
                <td id="eval_endterm_pr_total">PR-</td>
            </tr>
            <tr>
                <td>Class Participation:</td>
                <td><input type="text" id="eval_cp_th" name="eval_cp_th" readonly></td>
                <td><input type="text" id="eval_cp_pr" name="eval_cp_pr" readonly></td>
                <td>Written Examination</td>
                <td><input type="text" id="eval_written_exam_th" name="eval_written_exam_th" readonly></td>
                <td><input type="text" id="eval_written_exam_pr" name="eval_written_exam_pr" readonly value="NA"></td>
            </tr>
            <tr>
                <td>Seminar/presentation/assignment/quiz/class test etc.:</td>
                <td><input type="text" id="eval_seminar_th" name="eval_seminar_th" readonly></td>
                <td><input type="text" id="eval_seminar_pr" name="eval_seminar_pr" readonly></td>
                <td>Lab record</td>
                <td><input type="text" id="eval_lab_record_th" name="eval_lab_record_th" readonly value="NA"></td>
                <td><input type="text" id="eval_lab_record_pr" name="eval_lab_record_pr" readonly></td>
            </tr>
            <tr>
                <td>Seminar/Demonstration/Viva-voce/Lab records etc.:</td>
                <td><input type="text" id="eval_seminar_demo_th" name="eval_seminar_demo_th" readonly value="NA"></td>
                <td><input type="text" id="eval_seminar_demo_pr" name="eval_seminar_demo_pr" readonly></td>
                <td>Viva-Voce</td>
                <td><input type="text" id="eval_viva_th" name="eval_viva_th" readonly value="NA"></td>
                <td><input type="text" id="eval_viva_pr" name="eval_viva_pr" readonly></td>
            </tr>
            <tr>
                <td>Mid-Term Exam:</td>
                <td><input type="text" id="eval_midterm_th" name="eval_midterm_th" readonly></td>
                <td><input type="text" id="eval_midterm_pr" name="eval_midterm_pr" readonly value="NA"></td>
                <td>Write-up and execution of the practical</td>
                <td><input type="text" id="eval_execution_th" name="eval_execution_th" readonly value="NA"></td>
                <td><input type="text" id="eval_execution_pr" name="eval_execution_pr" readonly></td>
            </tr>
        </table>
    </div>

    <div class="form-section">
        <h2>Part C - Learning Resources</h2>
        <textarea name="resources" rows="6" placeholder="Enter each resource on a new line." required></textarea>
        <p><em>* Note: References should be formatted according to APA style guidelines.</em></p>
    </div>

    <hr>

    <div class="form-section">
        <h3>Mapping of CLOs to Program Outcomes</h3>
        <% if (typeof lockedPO !== 'undefined' && lockedPO !== null) { %>
            <div style="background-color: #d4edda; color: #155724; padding: 15px; border-radius: 5px; margin-bottom: 15px; text-align: center; border: 1px solid #c3e6cb;">
                <strong>This course is locked to its Curriculum Framework.</strong><br>
                Mapping is strictly enforced to <%= lockedPO %> POs and <%= lockedPSO %> PSOs based on the Programme Details.
            </div>
            <input type="hidden" id="numPOs" name="numPOs" value="<%= lockedPO %>">
            <input type="hidden" id="numPSOs" name="numPSOs" value="<%= lockedPSO %>">
        <% } else { %>
            <p>Enter mapping values (<strong>3</strong> for Strong, <strong>2</strong> for Medium, <strong>1</strong> for Weak) in the table below. The rows will sync with the CLOs you enter in Part A.</p>
            <div style="margin-bottom: 15px; display: flex; gap: 20px; align-items: center; justify-content: center; background-color: #f2f2f2; padding: 10px; border-radius: 4px;">
                <div>
                    <label for="numPOs" style="font-weight: bold;">Number of POs (8-12):</label>
                    <input type="number" id="numPOs" name="numPOs" min="8" max="12" value="11" onchange="generateMappingTable()" style="width: 80px; margin-left: 10px;">
                </div>
                <div>
                    <label for="numPSOs" style="font-weight: bold;">Number of PSOs (0-4):</label>
                    <input type="number" id="numPSOs" name="numPSOs" min="0" max="4" value="2" onchange="generateMappingTable()" style="width: 80px; margin-left: 10px;">
                </div>
            </div>
        <% } %>
        <table id="mappingTable" style="display: block; overflow-x: auto; white-space: nowrap;">
            <thead id="mappingHead">
                <!-- Mapping header will be generated here by JS -->
            </thead>
            <tbody id="mappingBody">
                <!-- Mapping rows will be generated here by JS -->
            </tbody>
        </table>
    </div>

    <div class="form-section">
        <h3>Content Mapping with NEP thrust areas</h3>
        <table>
            <tr class="section-title">
                <td>Field</td>
                <td>Content/s</td>
            </tr>
            <tr>
                <td class="header-cell">Employability/Entrepreneurship</td>
                <td><textarea name="nep_employability" rows="2"></textarea></td>
            </tr>
            <tr>
                <td class="header-cell">Skill Enhancement</td>
                <td><textarea name="nep_skill_enhancement" rows="2"></textarea></td>
            </tr>
            <tr>
                <td class="header-cell">Communication Development</td>
                <td><textarea name="nep_communication_development" rows="2"></textarea></td>
            </tr>
            <tr>
                <td class="header-cell">Indian Knowledge System</td>
                <td><textarea name="nep_indian_knowledge_system" rows="2"></textarea></td>
            </tr>
            <tr>
                <td class="header-cell">Environmental Awareness</td>
                <td><textarea name="nep_environmental_awareness" rows="2"></textarea></td>
            </tr>
            <tr>
                <td class="header-cell">Current Issues and Social Awareness</td>
                <td><textarea name="nep_current_issues" rows="2"></textarea></td>
            </tr>
            <tr>
                <td class="header-cell">Women empowerment/ Gender issues</td>
                <td><textarea name="nep_women_empowerment" rows="2"></textarea></td>
            </tr>
            <tr>
                <td class="header-cell">Public policies</td>
                <td><textarea name="nep_public_policies" rows="2"></textarea></td>
            </tr>
            <tr>
                <td class="header-cell">Any Other</td>
                <td><textarea name="nep_any_other" rows="2"></textarea></td>
            </tr>
        </table>
    </div>

    <button type="submit" class="submit-btn">Save Course</button>
</form>
</div>

<script src="/js/courseFormLogic.js"></script>

<script>
document.querySelector('form').addEventListener('submit', function(e) {
    const closText = document.getElementById("clos").value;
    const closList = closText.split(/\r?\n|\r/).map(c => c.trim()).filter(c => c !== "");
    if (closList.length < 2 || closList.length > 6) {
        e.preventDefault();
        alert("Please enter between 2 and 6 Course Learning Outcomes (CLOs) on separate lines.");
            return;
        }

        // Validate Contact Hours
        const theoryTotalCell = document.getElementById('theory_hours_total');
        if (theoryTotalCell) {
            const max = Number(theoryTotalCell.dataset.max);
            let current = 0;
            document.querySelectorAll('.contact-hour-theory').forEach(input => {
                current += Number(input.value) || 0;
            });
            if (current !== max) {
                e.preventDefault();
                alert(`Total theory contact hours (${current}) must exactly match the required total of ${max}.`);
                return;
            }
        }
        const practicalTotalCell = document.getElementById('practical_hours_total');
        if (practicalTotalCell) {
            const max = Number(practicalTotalCell.dataset.max);
            let current = 0;
            document.querySelectorAll('.contact-hour-practical').forEach(input => {
                current += Number(input.value) || 0;
            });
            if (current !== max) {
                e.preventDefault();
                alert(`Total practical contact hours (${current}) must exactly match the required total of ${max}.`);
                return;
            }
        }

        // Validate that Syllabus Topics are not empty
        const topics = document.querySelectorAll('input[name="unitContents[]"]');
        for (let i = 0; i < topics.length; i++) {
            if (!topics[i].value.trim()) {
                e.preventDefault();
                alert("Please enter topics for all Syllabus Units.");
                const editableDiv = topics[i].previousElementSibling;
                if (editableDiv) editableDiv.focus();
                return;
            }
    }
});
</script>

<% if (locals.course) { %>
<script>
document.addEventListener("DOMContentLoaded", () => {
    const course = <%- JSON.stringify(course) %>;
    
    const schemeSelect = document.getElementById("creditScheme");
    if(schemeSelect) {
        schemeSelect.value = course.credit_scheme || "";
        autofillForm(); // This generates the units and fills default scheme marks
    }

    // Text inputs
    const setVal = (name, val) => {
        const el = document.querySelector(`input[name="${name}"]`);
        if (el) el.value = val || "";
    };

    // Make crucial identifiers read-only to prevent accidental modification during edit
    const makeReadonly = (name) => {
        const el = document.querySelector(`input[name="${name}"]`);
        if (el) el.setAttribute("readonly", true);
    };

    setVal("semester", course.semester); // Keep

    let calculatedNature = course.nature_of_course || "";
    if (course.credits_theory > 0 && course.credits_practical > 0) calculatedNature = "Theory + Practical";
    else if (course.credits_theory > 0 && (!course.credits_practical || course.credits_practical == 0)) calculatedNature = "Theory(Theory + Tutorial)";
    else if ((!course.credits_theory || course.credits_theory == 0) && course.credits_practical > 0) calculatedNature = "Practical";
    setVal("natureOfCourse", calculatedNature);
    setVal("courseName", course.course_name);
    makeReadonly("courseName");
    setVal("courseCode", course.course_code);
    makeReadonly("courseCode");
    setVal("courseType", course.course_type);
    setVal("prerequisite", course.prerequisite);

    // Textareas
    const setTa = (name, val) => {
        const el = document.querySelector(`textarea[name="${name}"]`);
        if (el) el.value = val || "";
    };

    setTa("courseOutcomes", (course.course_outcomes || []).join('\n'));
    setTa("resources", course.learning_resources);

    if (course.nep_mapping) {
        setTa("nep_employability", course.nep_mapping.employability);
        setTa("nep_skill_enhancement", course.nep_mapping.skill_enhancement);
        setTa("nep_communication_development", course.nep_mapping.communication_development);
        setTa("nep_indian_knowledge_system", course.nep_mapping.indian_knowledge_system);
        setTa("nep_environmental_awareness", course.nep_mapping.environmental_awareness);
        setTa("nep_current_issues", course.nep_mapping.current_issues);
        setTa("nep_women_empowerment", course.nep_mapping.women_empowerment);
        setTa("nep_public_policies", course.nep_mapping.public_policies);
        setTa("nep_any_other", course.nep_mapping.any_other);
    }

    // Units
    if (course.syllabus_units && course.syllabus_units.length > 0) {
        const titleInputs = document.querySelectorAll('input[name="unitTitles[]"]');
        const contentInputs = document.querySelectorAll('input[name="unitContents[]"]');
        const cloInputs = document.querySelectorAll('input[name="unitCLOs[]"]');
        const hourInputs = document.querySelectorAll('input[name="unitHours[]"]');
        
        course.syllabus_units.forEach((unit, index) => {
            if (titleInputs[index]) titleInputs[index].value = unit.title || "";
            if (contentInputs[index]) {
                contentInputs[index].value = unit.content || "";
                const div = contentInputs[index].previousElementSibling;
                if(div && div.getAttribute('contenteditable')) {
                    div.innerHTML = unit.content || "";
                }
            }
            if (cloInputs[index]) cloInputs[index].value = unit.clos || "";
            if (hourInputs[index]) hourInputs[index].value = unit.hours || "";
        });
        // Update the contact hour totals display after populating
        validateContactHours();
    }

    // Mapping table
    let maxPO = 11;
    let maxPSO = 2;
    if (course.co_po_mapping && course.co_po_mapping.length > 0) {
        maxPO = 8;
        maxPSO = 0;
        course.co_po_mapping.forEach(m => {
            for(let i=1; i<=12; i++) if (m[`po${i}`] !== undefined) maxPO = Math.max(maxPO, i);
            for(let i=1; i<=4; i++) if (m[`pso${i}`] !== undefined) maxPSO = Math.max(maxPSO, i);
        });
    }

    <% if (typeof lockedPO !== 'undefined' && lockedPO !== null) { %>
        maxPO = <%= lockedPO %>;
        maxPSO = <%= lockedPSO %>;
    <% } %>

    const numPOsInput = document.getElementById("numPOs");
    const numPSOsInput = document.getElementById("numPSOs");
    if (numPOsInput) numPOsInput.value = maxPO;
    if (numPSOsInput) numPSOsInput.value = maxPSO;

    generateMappingTable();
    if (course.co_po_mapping && course.co_po_mapping.length > 0) {
        const tbody = document.getElementById("mappingBody");
        const rows = tbody.querySelectorAll("tr");
        course.co_po_mapping.forEach((mapping, index) => {
            if (rows[index]) {
                for (let i = 1; i <= maxPO; i++) {
                    const input = rows[index].querySelector(`input[name="mapPO${i}[]"]`);
                    if (input) input.value = mapping[`po${i}`] || "";
                }
                for (let i = 1; i <= maxPSO; i++) {
                    const input = rows[index].querySelector(`input[name="mapPSO${i}[]"]`);
                    if (input) input.value = mapping[`pso${i}`] || "";
                }
            }
        });
    }
});
</script>
<% } %>
</body>
</html>