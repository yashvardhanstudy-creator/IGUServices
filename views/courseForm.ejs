<head>
    <link rel="shortcut icon" href="https://igu1.ucanapply.com/images/webicon.png" type="image/png">
    <meta charset="UTF-8">
    <title>Course Entry Form - IGU Meerpur</title>
    <link rel="stylesheet" type="text/css" href="./stylesheets/index.css">
    <!-- Include Quill Rich Text Editor -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <style>
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        th,
        td {
            border: 1px solid black;
            padding: 8px;
            text-align: left;
        }

        th {
            background-color: #f2f2f2;
        }

        textarea,
        input[type="text"],
        input[type="number"] {
            width: 100%;
            box-sizing: border-box;
            padding: 6px;
        }

        textarea {
            resize: vertical;
            overflow: hidden;
            /* For auto-resize */
        }

        .dynamic-list {
            margin-top: 10px;
        }

        .dynamic-item {
            display: flex;
            gap: 10px;
            margin-bottom: 10px;
            width: 100%;
            align-items: flex-start;
        }

        .dynamic-item input[type="text"],
        .dynamic-item textarea {
            flex-grow: 1;
        }

        .action-btn {
            color: white;
            padding: 8px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            white-space: nowrap;
            font-weight: bold;
        }

        .remove-btn {
            background-color: #dc3545;
            padding: 6px 12px;
            margin-top: 2px;
        }

        .add-btn {
            background-color: #28a745;
            margin-bottom: 15px;
        }

        @page {
            size: auto;
            margin: 5mm;
            /* This removes the browser's default header and footer */
        }

        /* Print styling for official document look */
        @media print {

            .action-btn,
            .action-btn-col,
            #back,
            button {
                display: none !important;
            }

            input,
            textarea {
                border: none !important;
                background: transparent !important;
                resize: none !important;
                padding: 0 !important;
                font-size: 14px;
                font-family: serif;
                outline: none;
            }

            body {
                margin: 0;
                padding: 15mm;
                /* Adds a safe physical margin back to the content */
            }

            h1,
            h2,
            h3,
            p,
            table,
            th,
            td {
                font-family: serif;
            }

            /* Ensure proper printing of textareas */
            textarea {
                height: auto !important;
                overflow: visible !important;
            }

            /* Quill specific print styles */
            .ql-toolbar {
                display: none !important;
            }

            .ql-container.ql-snow {
                border: none !important;
            }

            .ql-editor {
                padding: 0 !important;
                overflow: visible !important;
            }
        }
    </style>
    <script>
        // Auto-resize textareas to fit content perfectly on print
        function resizeTextarea(el) {
            el.style.height = 'auto';
            el.style.height = (el.scrollHeight) + 'px';
        }

        // Quill Editor Configuration
        const quillOptions = {
            theme: 'snow',
            modules: {
                toolbar: [
                    ['bold', 'italic', 'underline'],
                    [{
                        'list': 'ordered'
                    }, {
                        'list': 'bullet'
                    }],
                    ['clean']
                ]
            }
        };

        // Attach to existing textareas on load
        window.onload = function () {
            const tx = document.getElementsByTagName("textarea");
            for (let i = 0; i < tx.length; i++) {
                tx[i].setAttribute("style", "height:" + (tx[i].scrollHeight) + "px;overflow-y:hidden;");
                tx[i].addEventListener("input", OnInput, false);
            }

      <% if (!course || !course.co_po_mapping || course.co_po_mapping.length === 0) { %>
                addMappingRow(); // Add first mapping row by default
      <% } %>

                // Initialize static Quill Editors
                new Quill('#editor_objectives', quillOptions);
            new Quill('#editor_importantNote', quillOptions);

      <% if (course && course.syllabus_units && course.syllabus_units.length > 0) { %>
      <% course.syllabus_units.forEach((unit, index) => { %>
                new Quill('#editor_unit_<%= index + 1 %>', quillOptions);
      <% }) %>
      <% } else { %>
                new Quill('#editor_unit_1', quillOptions);
      <% } %>
    }

        function OnInput() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        }

        function calculateMarks() {
            const cm = parseFloat(document.getElementById('classMarks').value) || 0;
            const em = parseFloat(document.getElementById('examMarks').value) || 0;
            const pm = parseFloat(document.getElementById('practicalMarks').value) || 0;
            document.getElementById('totalMarks').value = cm + em + pm;
        }

        function addDynamicField(containerId, inputName, placeholder) {
            const container = document.getElementById(containerId);
            const div = document.createElement('div');
            div.className = 'dynamic-item';
            div.innerHTML = `
                <input type="text" name="${inputName}[]" placeholder="${placeholder}" required>
                <button type="button" class="action-btn remove-btn" onclick="this.parentElement.remove()">Remove</button>
            `;
            container.appendChild(div);
        }

        function addUnit() {
            const container = document.getElementById('unitsContainer');
            const unitCount = container.children.length + 1;
            const div = document.createElement('div');
            div.className = 'dynamic-item';
            div.style.flexDirection = 'column';

            const editorId = 'editor_unit_' + Date.now();

            div.innerHTML = `
                <input type="text" name="unitTitles[]" placeholder="Unit: ${unitCount}" required style="font-weight: bold; font-size: 1.1em;">
                <input type="hidden" name="unitContents[]" class="hidden-unit-content">
                <div id="${editorId}" class="quill-unit-editor" style="min-height: 60px; width: 100%; font-family: serif; font-size: 14px;"></div>
                <button type="button" class="action-btn remove-btn" onclick="this.parentElement.remove()">Remove Unit</button>
            `;
            container.appendChild(div);

            // Initialize Quill on the newly added editor
            new Quill('#' + editorId, quillOptions);
        }

        // Sync Quill HTML content to hidden inputs right before form submission
        function syncQuill() {
            // Helper function to safely parse and justify HTML blocks
            function applyJustify(html) {
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = html;
                
                // Apply text-align: justify to all paragraphs and list items, unless manually overridden
                const blocks = tempDiv.querySelectorAll('p, li');
                blocks.forEach(block => {
                    if (!block.style.textAlign) {
                        block.style.textAlign = 'justify';
                    }
                });
                return tempDiv.innerHTML;
            }

            document.getElementById('hidden_objectives').value = applyJustify(document.querySelector('#editor_objectives .ql-editor').innerHTML);
            document.getElementById('hidden_importantNote').value = applyJustify(document.querySelector('#editor_importantNote .ql-editor').innerHTML);

            const unitEditors = document.querySelectorAll('.quill-unit-editor');
            const hiddenUnits = document.querySelectorAll('.hidden-unit-content');
            unitEditors.forEach((editor, index) => {
                hiddenUnits[index].value = applyJustify(editor.querySelector('.ql-editor').innerHTML);
            });
            return true;
        }

        function addMappingRow() {
            const tbody = document.getElementById('mappingBody');
            const rowCount = tbody.children.length + 1;
            const tr = document.createElement('tr');

            let html = `<td><input type="text" name="mapCO[]" value="CO${rowCount}" style="width: 60px; text-align: center; font-weight: bold;" required></td>`;

            // 11 POs
            for (let i = 1; i <= 11; i++) {
                html += `<td><input type="text" name="mapPO${i}[]" maxlength="1" style="width: 30px; text-align: center; text-transform: uppercase;"></td>`;
            }
            // 4 PSOs
            for (let i = 1; i <= 4; i++) {
                html += `<td><input type="text" name="mapPSO${i}[]" maxlength="1" style="width: 30px; text-align: center; text-transform: uppercase;"></td>`;
            }
            html += `<td class="action-btn-col"><button type="button" class="action-btn remove-btn" onclick="this.parentElement.parentElement.remove()">X</button></td>`;
            tr.innerHTML = html;
            tbody.appendChild(tr);
        }
    </script>
</head>

<body>
    <hr>
    <a href="/courses-list"><img id="back" src="/images/goBackArrow.png" type="png" alt="Go Back"
            style="width: 30px;"></a>

    <form action="/courses" method="POST" onsubmit="return syncQuill()">

        <h2><b><u>
                    <%="General Information"%>
                </u></b></h2>
        <table>
            <tr>
                <td style="width: 25%; font-weight: bold;">Course Code</td>
                <td>
                    <input type="text" name="courseCode" value="<%= course ? course.course_code : 'PCC-CSE-201' %>" required>
                    <% if (course) { %>
                        <small style="color: #6c757d; margin-top: 5px; display: inline-block;"><em>* Note: Changing this code and saving will create a new duplicated course. The original will remain unchanged.</em></small>
                    <% } %>
                </td>
            </tr>
            <tr>
                <td style="font-weight: bold;">Category</td>
                <td><input type="text" name="category"
                        value="<%= course ? course.category : 'Professional Core Course' %>"></td>
            </tr>
            <tr>
                <td style="font-weight: bold;">Course Title</td>
                <td><input type="text" name="courseTitle"
                        value="<%= course ? course.course_title : 'Database Management System' %>"></td>
            </tr>
            <tr>
                <td style="font-weight: bold;">Hours & Credit</td>
                <td style="padding: 0;">
                    <table style="width: 100%; margin-bottom: 0;">
                        <thead>
                            <tr>
                                <th style="text-align: center;">L</th>
                                <th style="text-align: center;">T</th>
                                <th style="text-align: center;">P</th>
                                <th style="text-align: center;">Credit</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <select id="l" name="l" style="width: 100%; padding: 6px; text-align: center;">
                                        <% for(let i=0; i<=4; i++) { %>
                                            <option value="<%= i %>" <%= course && course.l == i ? 'selected' : (i==3 && !course ? 'selected' : '') %>><%= i %></option>
                                        <% } %>
                                    </select>
                                </td>
                                <td>
                                    <select id="t" name="t" style="width: 100%; padding: 6px; text-align: center;">
                                        <% for(let i=0; i<=4; i++) { %>
                                            <option value="<%= i %>" <%= course && course.t == i ? 'selected' : (i==0 && !course ? 'selected' : '') %>><%= i %></option>
                                        <% } %>
                                    </select>
                                </td>
                                <td>
                                    <select id="p" name="p" style="width: 100%; padding: 6px; text-align: center;">
                                        <% for(let i=0; i<=4; i++) { %>
                                            <option value="<%= i %>" <%= course && course.p == i ? 'selected' : (i==0 && !course ? 'selected' : '') %>><%= i %></option>
                                        <% } %>
                                    </select>
                                </td>
                                <td><input type="number" id="credit" name="credit" value="<%= course ? course.credit : 3 %>"></td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>
            <tr>
                <td style="font-weight: bold;">Class Work</td>
                <td><input type="number" id="classMarks" name="classMarks"
                        value="<%= course ? course.class_marks : 25 %>" oninput="calculateMarks()"></td>
            </tr>
            <tr>
                <td style="font-weight: bold;">Exam</td>
                <td><input type="number" id="examMarks" name="examMarks" value="<%= course ? course.exam_marks : 75 %>"
                        oninput="calculateMarks()"></td>
            </tr>
            <tr>
                <td style="font-weight: bold;">Practical</td>
                <td><input type="number" id="practicalMarks" name="practicalMarks"
                        value="<%= course ? course.practical_marks : 0 %>" oninput="calculateMarks()"></td>
            </tr>
            <tr>
                <td style="font-weight: bold;">Total Marks</td>
                <td><input type="number" id="totalMarks" name="totalMarks"
                        value="<%= course ? course.total_marks : 100 %>" readonly style="background-color: #e9ecef;">
                </td>
            </tr>
            <tr>
                <td style="font-weight: bold;">Duration of Exam</td>
                <td><input type="text" name="examDuration" value="<%= course ? course.exam_duration : '03 Hours' %>">
                </td>
            </tr>
        </table>

        <h2><b><u>Objectives of the course</u></b></h2>
        <input type="hidden" name="objectives" id="hidden_objectives">
        <div id="editor_objectives" style="height: 100px; font-family: serif; font-size: 14px;"><%- course ?
                course.objectives
                : 'a. To understand the different issues involved in the design and implementation of a database system.<br>b. To study the physical and logical database designs, database modeling, relational, hierarchical, and network models.<br>c. To understand and use data manipulation language to query, update, and manage a database.'
                %></div>

        <h2><b><u>Important Note</u></b></h2>
        <div style="border: 1px solid black; padding: 8px; margin-bottom: 15px;">
            <input type="hidden" name="importantNote" id="hidden_importantNote">
            <div id="editor_importantNote" style="height: 100px; font-family: serif; font-size: 14px;"><%- course ?
                    course.important_note : '' %></div>
        </div>

        <h2><b><u>Syllabus Units</u></b></h2>
        <div id="unitsContainer">
            <% if (course && course.syllabus_units && course.syllabus_units.length> 0) { %>
                <% course.syllabus_units.forEach((unit, index)=> { %>
                    <div class="dynamic-item" style="flex-direction: column;">
                        <input type="text" name="unitTitles[]" value="<%= unit.title %>" required
                            style="font-weight: bold; font-size: 1.1em;">
                        <input type="hidden" name="unitContents[]" class="hidden-unit-content">
                        <div id="editor_unit_<%= index + 1 %>" class="quill-unit-editor"
                            style="min-height: 60px; width: 100%; font-family: serif; font-size: 14px;"><%- unit.content
                                %></div>
                        <button type="button" class="action-btn remove-btn" onclick="this.parentElement.remove()">Remove
                            Unit</button>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="dynamic-item" style="flex-direction: column;">
                                <input type="text" name="unitTitles[]" placeholder="Unit: 1" required
                                    style="font-weight: bold; font-size: 1.1em;">
                                <input type="hidden" name="unitContents[]" class="hidden-unit-content">
                                <div id="editor_unit_1" class="quill-unit-editor"
                                    style="min-height: 60px; width: 100%; font-family: serif; font-size: 14px;"></div>
                                <button type="button" class="action-btn remove-btn"
                                    onclick="this.parentElement.remove()">Remove
                                    Unit</button>
                            </div>
                            <% } %>
        </div>
        <button type="button" class="action-btn add-btn" onclick="addUnit()">Add Unit</button>

        <h2><b><u>Course Outcomes</u></b></h2>
        <div id="outcomesContainer" class="dynamic-list">
            <% if (course && course.course_outcomes && course.course_outcomes.length> 0) { %>
                <% course.course_outcomes.forEach(outcome=> { %>
                    <div class="dynamic-item">
                        <input type="text" name="courseOutcomes[]" value="<%= outcome %>" required>
                        <button type="button" class="action-btn remove-btn"
                            onclick="this.parentElement.remove()">Remove</button>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="dynamic-item">
                                <input type="text" name="courseOutcomes[]"
                                    placeholder="Enter Course Outcome (e.g., CO1 To introduce...)" required>
                                <button type="button" class="action-btn remove-btn"
                                    onclick="this.parentElement.remove()">Remove</button>
                            </div>
                            <% } %>
        </div>
        <button type="button" class="action-btn add-btn"
            onclick="addDynamicField('outcomesContainer', 'courseOutcomes', 'Enter Course Outcome')">Add
            Outcome</button>

        <h2><b><u>Suggested Books</u></b></h2>
        <div id="booksContainer" class="dynamic-list">
            <% if (course && course.suggested_books && course.suggested_books.length> 0) { %>
                <% course.suggested_books.forEach(book=> { %>
                    <div class="dynamic-item">
                        <input type="text" name="suggestedBooks[]" value="<%= book %>" required>
                        <button type="button" class="action-btn remove-btn"
                            onclick="this.parentElement.remove()">Remove</button>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="dynamic-item">
                                <input type="text" name="suggestedBooks[]" placeholder="Enter Book Details" required>
                                <button type="button" class="action-btn remove-btn"
                                    onclick="this.parentElement.remove()">Remove</button>
                            </div>
                            <% } %>
        </div>
        <button type="button" class="action-btn add-btn"
            onclick="addDynamicField('booksContainer', 'suggestedBooks', 'Enter Book Details')">Add Book</button>

        <h2><b><u>Suggested Reference Books</u></b></h2>
        <div id="referenceBooksContainer" class="dynamic-list">
            <% if (course && course.reference_books && course.reference_books.length> 0) { %>
                <% course.reference_books.forEach(book=> { %>
                    <div class="dynamic-item">
                        <input type="text" name="referenceBooks[]" value="<%= book %>" required>
                        <button type="button" class="action-btn remove-btn"
                            onclick="this.parentElement.remove()">Remove</button>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="dynamic-item">
                                <input type="text" name="referenceBooks[]" placeholder="Enter Reference Book Details"
                                    required>
                                <button type="button" class="action-btn remove-btn"
                                    onclick="this.parentElement.remove()">Remove</button>
                            </div>
                            <% } %>
        </div>
        <button type="button" class="action-btn add-btn"
            onclick="addDynamicField('referenceBooksContainer', 'referenceBooks', 'Enter Reference Book Details')">Add
            Reference Book</button>

        <h2><b><u>Mapping of Course Outcomes to Program Outcomes</u></b></h2>
        <div style="overflow-x: auto;">
            <table id="mappingTable" style="text-align: center;">
                <thead>
                    <tr>
                        <th style="text-align: center;">CO</th>
                        <th style="text-align: center;">PO1</th>
                        <th style="text-align: center;">PO2</th>
                        <th style="text-align: center;">PO3</th>
                        <th style="text-align: center;">PO4</th>
                        <th style="text-align: center;">PO5</th>
                        <th style="text-align: center;">PO6</th>
                        <th style="text-align: center;">PO7</th>
                        <th style="text-align: center;">PO8</th>
                        <th style="text-align: center;">PO9</th>
                        <th style="text-align: center;">PO10</th>
                        <th style="text-align: center;">PO11</th>
                        <th style="text-align: center;">PSO1</th>
                        <th style="text-align: center;">PSO2</th>
                        <th style="text-align: center;">PSO3</th>
                        <th style="text-align: center;">PSO4</th>
                        <th class="action-btn-col" style="text-align: center;">Action</th>
                    </tr>
                </thead>
                <tbody id="mappingBody">
                    <% if (course && course.co_po_mapping && course.co_po_mapping.length> 0) { %>
                        <% course.co_po_mapping.forEach((map, idx)=> { %>
                            <tr>
                                <td><input type="text" name="mapCO[]" value="<%= map.co %>"
                                        style="width: 60px; text-align: center; font-weight: bold;" required></td>
                                <% for(let i=1; i<=11; i++) { %>
                                    <td><input type="text" name="mapPO<%= i %>[]" value="<%= map['po'+i] %>"
                                            maxlength="1"
                                            style="width: 30px; text-align: center; text-transform: uppercase;"></td>
                                    <% } %>
                                        <% for(let i=1; i<=4; i++) { %>
                                            <td><input type="text" name="mapPSO<%= i %>[]" value="<%= map['pso'+i] %>"
                                                    maxlength="1"
                                                    style="width: 30px; text-align: center; text-transform: uppercase;">
                                            </td>
                                            <% } %>
                                                <td class="action-btn-col"><button type="button"
                                                        class="action-btn remove-btn"
                                                        onclick="this.parentElement.parentElement.remove()">X</button>
                                                </td>
                            </tr>
                            <% }) %>
                                <% } %>
                </tbody>
            </table>
        </div>
        <button type="button" class="action-btn add-btn" onclick="addMappingRow()">Add Mapping Row</button>
        <p style="font-weight: bold; margin-bottom: 20px;">S=Strong, M=Medium, W=Weak</p>

        <center>
            <button type="submit"
                style="padding: 10px 20px; font-size: 16px; margin-top: 20px; background-color: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer;">Save
                Course Data</button>
        </center>
    </form>

  
</body>

</html>