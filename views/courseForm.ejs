<script>
document.querySelector('form').addEventListener('submit', function(e) {
        const cloInputs = document.querySelectorAll('textarea[name="courseOutcomes[]"]');
        let validCLOCount = 0;
        cloInputs.forEach(input => { if (input.value.trim() !== '') validCLOCount++; });
        
        if (validCLOCount < 2 || validCLOCount > 6) {
            e.preventDefault();
            alert("Please enter between 2 and 6 Course Learning Outcomes (CLOs).");
            return;
        }

        const resources = document.querySelectorAll('input[name="resources[]"]');
        let validResourceCount = 0;
        for (let i = 0; i < resources.length; i++) {
            let val = resources[i].value.replace(/<[^>]*>?/gm, '').trim();
            if (val !== '') validResourceCount++;
        }
        
        if (validResourceCount < 5) {
            e.preventDefault();
            alert("Please enter a minimum of 5 learning resources.");
            return;
        }

        // Validate Contact Hours
        const theoryTotalCell = document.getElementById('theory_hours_total');
        if (theoryTotalCell) {
            const max = Number(theoryTotalCell.dataset.max);
            let current = 0;
            document.querySelectorAll('.contact-hour-theory').forEach(input => {
                current += Number(input.value) || 0;
            });
            if (current !== max) {
                e.preventDefault();
                alert(`Total theory contact hours (${current}) must exactly match the required total of ${max}.`);
                return;
            }
        }
        const practicalTotalCell = document.getElementById('practical_hours_total');
        if (practicalTotalCell) {
            const max = Number(practicalTotalCell.dataset.max);
            let current = 0;
            document.querySelectorAll('.contact-hour-practical').forEach(input => {
                current += Number(input.value) || 0;
            });
            if (current !== max) {
                e.preventDefault();
                alert(`Total practical contact hours (${current}) must exactly match the required total of ${max}.`);
                return;
            }
        }

        // Validate that Syllabus Topics are not empty
        const topics = document.querySelectorAll('input[name="unitContents[]"]');
        for (let i = 0; i < topics.length; i++) {
            if (!topics[i].value.trim()) {
                e.preventDefault();
                alert("Please enter topics for all Syllabus Units.");
                const editableDiv = topics[i].previousElementSibling;
                if (editableDiv) editableDiv.focus();
                return;
            }
    }
});
</script>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const courseCodeInput = document.getElementById("courseCodeInput");
    const isEditMode = document.querySelector('input[name="isEditMode"]').value === 'true';

    // Client-side instant validation to prevent duplicate course codes for new courses
    if (courseCodeInput && !isEditMode) {
        courseCodeInput.addEventListener("blur", async function() {
            const code = this.value.trim();
            if (!code) return;
            try {
                const response = await fetch('/api/course/' + encodeURIComponent(code));
                const data = await response.json();
                if (data.exists) {
                    alert('Course code "' + code + '" already exists in the database! Please use a unique course code.');
                    this.value = '';
                    if (typeof generateMappingTable === 'function') generateMappingTable();
                    this.focus();
                }
            } catch (e) {
                console.error("Error validating course code:", e);
            }
        });
    }
});
</script>

