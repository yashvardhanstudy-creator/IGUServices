<script>
    function addResourceInput(value = '') {
        const container = document.getElementById('learning-resources-container');
        const div = document.createElement('div');
        div.style.display = 'flex';
        div.style.gap = '10px';
        div.style.marginBottom = '10px';
        const safeValue = value.replace(/"/g, '&quot;');
        div.innerHTML = `
            <div style="flex: 1; display: flex; flex-direction: column; gap: 5px;">
                <div style="display: flex; gap: 5px;">
                    <button type="button" class="rt-btn" onmousedown="event.preventDefault(); document.execCommand('bold', false, null)" title="Bold">B</button>
                    <button type="button" class="rt-btn" onmousedown="event.preventDefault(); document.execCommand('italic', false, null)" title="Italic" style="font-style: italic;">I</button>
                    <button type="button" class="rt-btn" onmousedown="event.preventDefault(); document.execCommand('underline', false, null)" title="Underline" style="text-decoration: underline;">U</button>
                </div>
                <div contenteditable="true" style="border: 1px solid #ccc; padding: 8px; min-height: 20px; border-radius: 4px; background-color: #fff; outline: none;" oninput="this.nextElementSibling.value = this.innerHTML" placeholder="Enter learning resource">${value}</div>
                <input type="hidden" name="resources[]" value="${safeValue}">
            </div>
            <button type="button" onclick="if(document.getElementById('learning-resources-container').children.length > 5) { this.parentElement.remove(); } else { this.previousElementSibling.querySelector('div[contenteditable]').innerHTML = ''; this.previousElementSibling.querySelector('input[type=hidden]').value = ''; }" style="padding: 8px 12px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; height: fit-content; align-self: center; margin-top: 28px;">X</button>
        `;
        container.appendChild(div);
    }

    document.addEventListener("DOMContentLoaded", () => {
        <% if (typeof course !== 'undefined' && course.learning_resources) { %>
            const resourcesText = <%- JSON.stringify(course.learning_resources || '') %>;
            let resources = [];
            if (resourcesText.includes('<ul')) {
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = resourcesText;
                const lis = tempDiv.querySelectorAll('li');
                lis.forEach(li => resources.push(li.innerHTML));
            } else {
                resources = resourcesText ? resourcesText.split(/\r?\n|\r/) : [];
            }
            let loadedCount = 0;
            if (resources.length > 0) {
                resources.forEach(res => {
                    if (res.trim()) {
                        addResourceInput(res.trim());
                        loadedCount++;
                    }
                });
            }
            while (loadedCount < 5) {
                addResourceInput();
                loadedCount++;
            }
        <% } else { %>
            for (let i = 0; i < 5; i++) {
                addResourceInput();
            }
        <% } %>
    });
    
    // Smart Paste Sanitizer: 
    // Intercept paste events to strip weird fonts/colors from MS Word or Webpages,
    // but preserve essential structural HTML like links (<a>), bold (<b>), and lists (<ul>/<li>).
    document.addEventListener('paste', function(e) {
        const target = e.target;
        if (target && target.isContentEditable) {
            e.preventDefault();
            
            const clipboardHTML = (e.originalEvent || e).clipboardData.getData('text/html');
            const plainText = (e.originalEvent || e).clipboardData.getData('text/plain');

            if (clipboardHTML) {
                // Create a temporary container to safely parse the HTML
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = clipboardHTML;

                // Remove potentially harmful or layout-breaking tags completely
                const tagsToRemove = tempDiv.querySelectorAll('script, style, meta, link, img, picture, figure');
                tagsToRemove.forEach(el => el.remove());

                // Iterate through all remaining elements and strip their styling/classes
                const allElements = tempDiv.querySelectorAll('*');
                allElements.forEach(el => {
                    // Keep only the href attribute on anchor tags, strip everything else (style, class, id, etc.)
                    Array.from(el.attributes).forEach(attr => {
                        if (!(el.tagName === 'A' && attr.name === 'href')) {
                            el.removeAttribute(attr.name);
                        }
                    });
                });
                document.execCommand('insertHTML', false, tempDiv.innerHTML);
            } else {
                // Fallback to plain text
                document.execCommand('insertText', false, plainText);
            }
        }
    });

    function addCLOInput(val = '') {
        const container = document.getElementById('clo_container');
        if (container.children.length >= 6) {
            alert('Maximum 6 CLOs allowed.');
            return;
        }
        const div = document.createElement('div');
        div.style.display = 'flex';
        div.style.gap = '10px';
        div.style.marginBottom = '10px';
        div.style.borderBottom = '1px solid #ccc';
        div.style.paddingBottom = '10px';
        div.innerHTML = `
            <textarea name="courseOutcomes[]" rows="2" style="flex: 1; padding: 8px; border: 1px solid #ccc; border-radius: 4px; resize: vertical;" required>${val}</textarea>
            <button type="button" onclick="if(document.getElementById('clo_container').children.length > 2) { this.parentElement.remove(); if(typeof generateMappingTable === 'function') generateMappingTable(); if(typeof syncUnitCLOCheckboxes === 'function') syncUnitCLOCheckboxes(); } else { alert('Minimum 2 CLOs required.'); }" style="padding: 8px 12px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">X</button>
        `;
        container.appendChild(div);
        if (typeof generateMappingTable === 'function') generateMappingTable();
        if (typeof syncUnitCLOCheckboxes === 'function') syncUnitCLOCheckboxes();
    }

    document.addEventListener("DOMContentLoaded", () => {
        <% if (typeof course === 'undefined' || !course.course_outcomes || course.course_outcomes.length === 0) { %>
            addCLOInput();
            addCLOInput();
        <% } %>
    });
</script>
</body>
