<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="shortcut icon" href="https://igu1.ucanapply.com/images/webicon.png" type="image/png">
    <meta charset="UTF-8">
    <title>Saved Semester Structures</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
            background-color: #f4f7f6;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
            max-width: 900px;
            width: 100%;
        }

        h1 {
            text-align: center;
            color: #333;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th,
        td {
            padding: 12px 15px;
            border-bottom: 1px solid #ddd;
            text-align: left;
        }

        th {
            background-color: #f8f9fa;
        }

        .action-btn {
            padding: 6px 12px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            text-decoration: none;
            color: white;
            font-size: 14px;
            margin-right: 5px;
        }

        .view-btn {
            background-color: #17a2b8;
        }

        .edit-btn {
            background-color: #ffc107;
            color: black;
        }

        .back-btn {
            display: inline-block;
            margin-bottom: 20px;
            padding: 8px 15px;
            background-color: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }
    </style>
</head>

<body>
    <div class="container">
        <a href="/" class="back-btn">← Go Back</a>
        <h1>Saved Semester Structures</h1>
        <% if (structures.length === 0) { %>
            <p style="text-align: center; margin-top: 20px;">No semester structures have been saved yet.</p>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Semester</th>
                        <th>Academic Program</th>
                        <th>Specialization</th>
                        <th>Year Onward</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% structures.forEach(structure => { %>
                        <tr>
                            <td><strong><%= structure.semester %></strong></td>
                            <td><%= structure.academic_program %></td>
                            <td><%= structure.specialization %></td>
                            <td><%= structure.year_onward %></td>
                            <td>
                                <a href="/view-semester-structure?semester=<%= encodeURIComponent(structure.semester) %>&academic_program=<%= encodeURIComponent(structure.academic_program) %>&specialization=<%= encodeURIComponent(structure.specialization) %>&year_onward=<%= encodeURIComponent(structure.year_onward) %>" class="action-btn view-btn">View</a>
                                <a href="/semester-courses-form?semester=<%= encodeURIComponent(structure.semester) %>&academic_program=<%= encodeURIComponent(structure.academic_program) %>&specialization=<%= encodeURIComponent(structure.specialization) %>&year_onward=<%= encodeURIComponent(structure.year_onward) %>" class="action-btn edit-btn">Edit</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>
</body>

</html>