<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Program Details - <%= program.subject_name %></title>
    <style>
        body { font-family: 'Times New Roman', serif; padding: 20px; background-color: #f4f7f6; }
        .container { max-width: 950px; margin: auto; background: white; border: 1px solid #ccc; padding: 25px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        h1, h2, h3 { text-align: center; color: #333; }
        .form-section { border: 1px solid #e0e0e0; padding: 20px; margin-bottom: 25px; border-radius: 5px; }
        label { font-weight: bold; display: block; margin-top: 15px; margin-bottom: 5px; }
        input[type="text"], input[type="date"], textarea { width: 100%; padding: 8px; box-sizing: border-box; border-radius: 4px; border: 1px solid #ccc; }
        input[readonly] { background-color: #e9ecef; cursor: not-allowed; color: #6c757d; }
        textarea { min-height: 80px; resize: vertical; text-align: justify; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
        .btn { padding: 12px 25px; background-color: #28a745; color: white; border: none; border-radius: 5px; cursor: pointer; font-size: 16px; }
        .guidelines { background-color: #fff3cd; border-left: 5px solid #ffeeba; padding: 15px; margin-top: 20px; font-size: 14px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Program Details</h1>
        <h2><%= program.subject_name %> (<%= program.specialization || 'General' %>)</h2>

        <% if (locals.query && locals.query.error) { %>
            <div style="color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;"><%= locals.query.error %></div>
        <% } %>

        <form action="/program-details-form" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="program_code" value="<%= program.program_code %>">
            <div class="form-section">
                <h3>Cover Page Details</h3>
                <label for="title">Syllabus Title (e.g., Subject Name)</label>
                <input type="text" id="title" name="title" value="<%= programDetails.title || '' %>">
                <div class="form-group">
                    <label for="printed_program_code">Program Code (For Printing)</label>
                    <input type="text" id="printed_program_code" name="printed_program_code" value="<%= programDetails.program_code || '' %>" placeholder="e.g. BTECH-CS-01 (Leave blank to hide)">
                </div>
                <label for="academic_year">Effective from Academic Session</label>
                <input type="text" id="academic_year" name="academic_year" placeholder="e.g., 2024-25" value="<%= programDetails.academic_year || '' %>">

                <label for="faculty">Faculty of</label>
                <select id="faculty" name="faculty" onchange="populateDepartments('faculty', 'department', '', 'dept_container')">
                    <option value="">-- Select Faculty --</option>
                </select>

                <div id="dept_container" style="display: none;">
                    <label for="department">Department of</label>
                    <select id="department" name="department">
                        <option value="">-- Select Department --</option>
                    </select>
                </div>
            </div>

            <div class="form-section">
                <h3>Details of Approvals</h3>
                <p style="font-size: 14px; color: #555;">Please <a href="/download-approval-template" target="_blank" style="color: #007bff; text-decoration: underline;">download the blank Approval Details template</a>, get it filled and signed, and upload the scanned single-page PDF here.</p>
                <input type="file" name="approval_pdf" accept="application/pdf" style="margin-bottom: 10px; background-color: #f8f9fa;">
                <% if (programDetails.approval_pdf) { %>
                    <div style="background-color: #d4edda; color: #155724; padding: 10px; border-radius: 5px; margin-bottom: 10px; border: 1px solid #c3e6cb;">
                        ✅ <strong>Current File:</strong> <a href="/uploads/<%= programDetails.approval_pdf %>" target="_blank" style="color: #155724; text-decoration: underline;">View Uploaded PDF</a>
                    </div>
                <% } %>
                <input type="hidden" name="existing_approval_pdf" value="<%= programDetails.approval_pdf || '' %>">
            </div>
            
            <div class="form-section">
                <h3>Department & Programme Details</h3>
                <label for="vision_mission_dept">VISION AND MISSION OF THE DEPARTMENT</label>
                <textarea id="vision_mission_dept" name="vision_mission_dept"><%= programDetails.vision_mission_dept || '' %></textarea>
                
                <label for="about_programme">ABOUT THE PROGRAMME</label>
                <textarea id="about_programme" name="about_programme"><%= programDetails.about_programme || '' %></textarea>

                <label for="intake">INTAKE IN THE PROGRAMME</label>
                <textarea id="intake" name="intake"><%= programDetails.intake || '' %></textarea>

                <label for="min_eligibility">MINIMUM ELIGIBILITY CRITERIA</label>
                <textarea id="min_eligibility" name="min_eligibility"><%= programDetails.min_eligibility || '' %></textarea>

                <label for="passing_criteria">PASSING CRITERIA</label>
                <textarea id="passing_criteria" name="passing_criteria"><%= programDetails.passing_criteria || '' %></textarea>

                <label for="eligibility_exam">ELIGIBILITY FOR EXAMINATION</label>
                <textarea id="eligibility_exam" name="eligibility_exam"><%= programDetails.eligibility_exam || '' %></textarea>
            </div>
            
            <div class="form-section">
                <h3>Scheme of Examination Override (Optional)</h3>
                <p style="font-size: 14px; color: #555;">The system auto-calculates these values. Only fill these inputs if you want to force specific text in the printed Scheme of Examination table.</p>
                <table style="border: none; margin-top: 0;">
                    <tr>
                        <td style="border: none; padding: 5px;"><label>Total number of Semesters</label><input type="text" name="scheme_total_semesters" value="<%= programDetails.scheme_total_semesters || '' %>" placeholder="Auto-calculated if blank"></td>
                        <td style="border: none; padding: 5px;"><label>Total Marks</label><input type="text" name="scheme_total_marks" value="<%= programDetails.scheme_total_marks || '' %>" placeholder="Auto-calculated if blank"></td>
                    </tr>
                    <tr>
                        <td style="border: none; padding: 5px;"><label>Total Credit</label><input type="text" name="scheme_total_credits" value="<%= programDetails.scheme_total_credits || '' %>" placeholder="Auto-calculated if blank"></td>
                        <td style="border: none; padding: 5px;"><label>Framework</label><input type="text" name="scheme_framework" value="<%= programDetails.scheme_framework || '' %>" placeholder="Auto-calculated if blank"></td>
                    </tr>
                    <tr>
                        <td style="border: none; padding: 5px;" colspan="2"><label>Scheme Name</label><input type="text" name="scheme_name_override" value="<%= programDetails.scheme_name_override || '' %>" placeholder="e.g. Scheme A"></td>
                    </tr>
                </table>
            </div>

            <div class="form-section">
                <h3>Programme Objectives</h3>
                
                <div id="peo-container">
                    <h4>PROGRAMME EDUCATIONAL OBJECTIVES (PEOs)</h4>
                    <table><tbody id="peo-body"></tbody></table>
                </div>

                <div id="po-container" style="margin-top: 20px;">
                    <h4>PROGRAMME OBJECTIVES (POs)</h4>
                    <table><tbody id="po-body"></tbody></table>
                </div>

                <% if (program.num_psos > 0) { %>
                <div id="pso-container" style="margin-top: 20px;">
                    <h4>PROGRAMME SPECIFIC OBJECTIVES (PSOs)</h4>
                    <table><tbody id="pso-body"></tbody></table>
                </div>
                <% } %>
            </div>

            <div class="guidelines">
                <h4>Guidelines</h4>
                <p>1. One must adhere to the NEP guidelines and NHEQF guidelines for designing of the syllabus.</p>
                <p>2. It is mandatory for Mandates for Outcome-Based Framework as the core model. Requires 08-12 POs, 3-4 PSOs (wherever applicable) and 4-6 COs per course. Mapping matrices are compulsory with 3/2/1 scale (3 for strong, 2 for medium, 1 for weak mapping). The cell may be kept blank if particular CLO is not correlated with any of the POs/PSOs.</p>
                <p>3. The table below each course content must be filled (focus of the course), which describes various fields the course focuses on. The content should be clearly mentioned and at the end, total percentage of each field must be given for every programme.</p>
            </div>

            <div style="text-align: center; margin-top: 30px;">
                <button type="submit" class="btn" id="submitBtn">Save Details & Generate Syllabus</button>
            </div>
        </form>
    </div>

    <script src="/js/facultyDept.js"></script>
    <script>
        const initialData = <%- JSON.stringify(programDetails) %>;
        const posPlaceholders = [
            "Knowledge",
            "Research Aptitude",
            "Communication",
            "Problem Solving",
            "Individual and Team Work",
            "Investigation of Problems",
            "Modern Tool Usage",
            "Scientific Temperament",
            "Life-long Learning",
            "Ethics",
            "Project Management",
            "Entrepreneurship"
        ];
        function addRow(type, value = '', placeholder = '') {
            const container = document.getElementById(`${type}-body`);
            const index = container.rows.length;
            const row = container.insertRow();
            row.innerHTML = `
                <td style="width: 10%; font-weight: bold;">${type.toUpperCase()}${index + 1}</td>
                <td><textarea name="${type}[]" rows="2" placeholder="${placeholder}" required>${value}</textarea></td>
            `;
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Pre-populate PEOs
            const peos = initialData.peos || [];
            const numPeos = <%= program.num_peos %>;
            for (let i = 0; i < numPeos; i++) {
                addRow('peo', peos[i] || '');
            }

            // Pre-populate POs
            const pos = initialData.pos || [];
            const numPos = <%= program.num_pos %>;
            for (let i = 0; i < numPos; i++) {
                addRow('po', pos[i] || '', posPlaceholders[i] || '');
            }

            // Pre-populate PSOs
            const psos = initialData.psos || [];
            const numPsos = <%= program.num_psos %>;
            if (numPsos > 0) {
                for (let i = 0; i < numPsos; i++) {
                    addRow('pso', psos[i] || '');
                }
            }
            
            // Add loading state to submit button
            document.querySelector('form').addEventListener('submit', function() {
                const btn = document.getElementById('submitBtn');
                btn.disabled = true;
                btn.innerHTML = '⏳ Saving & Generating... Please wait';
                btn.style.backgroundColor = '#6c757d';
            });
            
            initFacultyDropdown('faculty', 'department', initialData.faculty || '', initialData.department || '', 'dept_container');
        });
    </script>
</body>
</html>