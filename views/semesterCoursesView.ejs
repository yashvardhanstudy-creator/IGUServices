<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <link rel="shortcut icon" href="https://igu1.ucanapply.com/images/webicon.png" type="image/png">
    <title>Semester Structure - <%= structure.specialization %></title>
    <style>
        body {
            font-family: serif;
            line-height: 1.5;
            color: black;
            margin: 20px auto;
            max-width: 900px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        th, td {
            border: 1px solid black;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }
        th {
            background-color: #f2f2f2;
            text-align: center;
        }
        .text-center { text-align: center; }
        .section-title {
            font-weight: bold;
            text-decoration: underline;
            margin-top: 25px;
            margin-bottom: 10px;
            font-size: 1.2em;
        }
        .print-btn, .back-btn {
            display: block;
            margin-bottom: 20px;
        }
        @media print {
            .print-btn, .back-btn { display: none !important; }
            body { max-width: 100%; }
        }
    </style>
</head>

<body>
    <a href="/semester-courses-list" class="back-btn"><img src="/images/goBackArrow.png" alt="Go Back" style="width: 30px;"></a>

    <center>
        <h1>Indira Gandhi University, Meerpur</h1>
        <img src="https://d2xe8shibzpjog.cloudfront.net/logo/igu_logo.png" style="max-height: 100px;">
        <h3>Scheme of Studies/Examination</h3>
        <h4><%= structure.academic_program %> (<%= structure.specialization %>)</h4>
        <h5>w.e.f. <%= structure.year_onward %></h5>
    </center>

    <hr>
    
    <h2 style="text-align: center;">Semester-<%= structure.semester %></h2>

    <table>
        <thead>
            <tr>
                <th rowspan="2">Sr. No.</th>
                <th rowspan="2">Course Code</th>
                <th rowspan="2">Course Title</th>
                <th colspan="4">Hours per week</th>
                <th rowspan="2">Credit</th>
                <th colspan="4">Examination Schedule (Marks)</th>
                <th rowspan="2">Duration of Exam (Hours)</th>
            </tr>
            <tr>
                <th>L</th>
                <th>T</th>
                <th>P</th>
                <th>Total</th>
                <th>Class Work</th>
                <th>Theory</th>
                <th>Practical</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            <% courses.forEach((course, index) => { %>
                <tr>
                    <td class="text-center"><%= index + 1 %></td>
                    <td><%= course.course_code %></td>
                    <td <%- course.is_missing ? 'style="color: red; font-weight: bold;"' : '' %>><%= course.course_title %></td>
                    <td class="text-center"><%= course.l %></td>
                    <td class="text-center"><%= course.t %></td>
                    <td class="text-center"><%= course.p %></td>
                    <td class="text-center"><%= course.is_missing ? '-' : (Number(course.l) + Number(course.t) + Number(course.p)) %></td>
                    <td class="text-center"><b><%= course.credit %></b></td>
                    <td class="text-center"><%= course.class_marks %></td>
                    <td class="text-center"><%= course.exam_marks %></td>
                    <td class="text-center"><%= course.practical_marks %></td>
                    <td class="text-center"><b><%= course.total_marks %></b></td>
                    <td class="text-center"><%= course.exam_duration %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <% if (structure.important_note && structure.important_note.length > 0) { %>
        <div class="section-title">NOTE:</div>
        <ul>
            <% structure.important_note.forEach(note => { %>
                <li><%= note %></li>
            <% }) %>
        </ul>
    <% } %>

    <button class="print-btn" onclick="window.print()" style="width: 200px; margin: 30px auto; padding: 10px; background-color: #6c757d; color: white; text-align: center; border-radius: 5px; cursor: pointer; font-family: sans-serif; font-size: 16px; border: none;">Print Document</button>

</body>
</html>