<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="shortcut icon" href="https://igu1.ucanapply.com/images/webicon.png" type="image/png">
    <title>Complete Syllabus - <%= specialization %></title>
    <style>
        body { font-family: 'Times New Roman', serif; line-height: 1.4; color: #000; margin: 0; padding: 20px; }
        .container { width: 90%; margin: auto; max-width: 1000px; }
        
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; table-layout: fixed; }
        th, td { border: 1px solid black; padding: 5px; vertical-align: top; word-wrap: break-word; }
        
        .header-cell { font-weight: bold; width: 35%; }
        .section-title { text-align: center; font-weight: bold; background-color: #f2f2f2; }
        
        .justified-text { text-align: justify; text-justify: inter-word; }
        .center { text-align: center; }
        .bold { font-weight: bold; }

        .col-label { width: 40%; }
        .col-val { width: 20%; text-align: center; }

        .print-btn {
            display: inline-block;
            width: 200px;
            margin: 10px;
            padding: 10px;
            background-color: #6c757d;
            color: white;
            text-align: center;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
            border: none;
        }

        .cover-page {
            height: 90vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .page-break-before { page-break-before: always; padding-top: 20px; }
        
        @media print {
            body { max-width: 100%; margin: 0; padding: 0; }
            .print-btn { display: none !important; }
            .action-buttons { display: none !important; }
            .container { width: 100%; }
            tr, .unit-block { page-break-inside: avoid; }
            a { text-decoration: none; color: black; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="action-buttons center" style="margin-top: 20px; margin-bottom: 20px;">
            <button class="print-btn" onclick="window.print()">Print Syllabus</button>
            <button class="print-btn" onclick="window.location.href='/download-full-syllabus-pdf?academic_program=<%= encodeURIComponent(academic_program) %>&specialization=<%= encodeURIComponent(specialization) %>' ">Download PDF</button>
        </div>

        <!-- Page 1: Cover Page -->
        <div class="cover-page">
            <img src="https://d2xe8shibzpjog.cloudfront.net/logo/igu_logo.png" alt="IGU Logo" style="max-height: 180px; margin-bottom: 30px;">
            <h1 style="font-size: 2.5em; text-align: center; margin-bottom: 10px;">Indira Gandhi University, Meerpur</h1>
            <h2 style="font-size: 1.8em; margin-top: 50px; text-align: center;">Syllabus for</h2>
            <h1 style="font-size: 2.8em; margin: 10px 0; text-align: center; text-decoration: underline;"><%= academic_program %></h1>
            <h2 style="font-size: 1.8em; text-align: center;">Specialization: <%= specialization %></h2>
        </div>

        <!-- Page 2: Master Curriculum Table -->
        <div class="page-break-before">
            <h2 class="center">Curriculum Framework</h2>
            <table>
                <thead>
                    <tr class="section-title">
                        <th>Semester</th>
                        <th>Course Type</th>
                        <th>Course Code</th>
                        <th>Nomenclature of course</th>
                        <th>Theory(T) / Practical(P)</th>
                        <th>Credit</th>
                        <th>Contact hours per week</th>
                        <th>Internal Assessment Marks</th>
                        <th>End Term Examination Marks</th>
                        <th>Total Marks</th>
                        <th>Exam Hours</th>
                    </tr>
                </thead>
                <tbody>
                    <% semesters.forEach(sem => { %>
                        <% sem.detailed_courses.forEach((course, index) => { %>
                            <tr>
                                <% if (index === 0) { %>
                                    <td rowspan="<%= sem.detailed_courses.length %>" class="center bold" style="vertical-align: middle;">Semester <%= sem.semester %></td>
                                <% } %>
                                <td><a href="#course-<%= course.course_code %>" style="color: #0056b3; text-decoration: underline;"><%= course.course_type || course.category || sem.courses_code[index] %></a></td>
                                <td><%= course.course_code %></td>
                                <td <%- course.is_missing ? 'style="color: red; font-weight: bold;"' : '' %>><%= course.course_name || course.course_title %></td>
                                <td class="center"><%= course.is_missing ? '-' : ((course.credits_theory || 0) + 'T / ' + (course.credits_practical || 0) + 'P') %></td>
                                <td class="center"><%= course.is_missing ? '-' : (course.credits_total || 0) %></td>
                                <td class="center"><%= course.is_missing ? '-' : ((course.credits_theory || 0) + ((course.credits_practical || 0) * 2)) %></td>
                                <td class="center"><%= course.is_missing ? '-' : (course.marks_internal_total || 0) %></td>
                                <td class="center"><%= course.is_missing ? '-' : (course.marks_endterm_total || ((course.marks_endterm_theory || 0) + (course.marks_endterm_practical || 0))) %></td>
                                <td class="center"><%= course.is_missing ? '-' : (course.marks_max || 0) %></td>
                                <td class="center"><%= course.is_missing ? '-' : (course.exam_duration || '-') %></td>
                            </tr>
                        <% }) %>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- Page 3+: Detailed Course Syllabi -->
        <% allCourses.forEach(data => { %>
            <% if (!data.is_missing) { %>
                <% 
                    // Determine which semester this course is mapped to in this program
                    let courseSem = [];
                    semesters.forEach(s => {
                        if(s.courses_code.includes(data.course_code)) courseSem.push(s.semester);
                    });
                    const clos = Array.isArray(data.course_outcomes) ? data.course_outcomes : [];
                    const units = Array.isArray(data.syllabus_units) ? data.syllabus_units : [];
                    const mappings = Array.isArray(data.co_po_mapping) ? data.co_po_mapping : [];
                %>
                
                <div class="page-break-before" id="course-<%= data.course_code %>">
                    
                    <table>
                        <tr><td colspan="4" class="section-title">Part A – Introduction</td></tr>
                        <tr><td class="header-cell">Name of the Programme</td><td colspan="3"><%= academic_program %> (<%= specialization %>)</td></tr>
                        <tr><td class="header-cell">Semester</td><td colspan="3">Semester <%= courseSem.join(', ') %></td></tr>
                        <tr><td class="header-cell">Nature of Course/Course Composition</td><td colspan="3"><%= data.nature_of_course || '-' %></td></tr>
                        <tr><td class="header-cell">Name of the Course</td><td colspan="3"><%= data.course_name || data.course_title %></td></tr>
                        <tr><td class="header-cell">Course Code</td><td colspan="3"><%= data.course_code %></td></tr>
                        <tr><td class="header-cell">Course Type</td><td colspan="3"><%= data.course_type || '-' %></td></tr>
                        <tr><td class="header-cell">Pre-requisite for the course (if any)</td><td colspan="3"><%= data.prerequisite || 'Nil' %></td></tr>
                        <tr>
                            <td class="header-cell">Course Learning Outcomes (CLOs)<br>After completing this course, the learner will be able to:</td>
                            <td colspan="3">
                                <% clos.forEach((clo, i) => { %>
                                    CLO<sub><%= i+1 %></sub>: <%= clo %><br>
                                <% }) %>
                            </td>
                        </tr>
                        <tr class="center bold">
                            <td></td><td>Theory</td><td>Practical</td><td>Total</td>
                        </tr>
                        <tr>
                            <td class="bold">Credits</td>
                            <td class="center"><%= data.credits_theory || 0 %></td><td class="center"><%= data.credits_practical || 0 %></td><td class="center"><%= data.credits_total || 0 %></td>
                        </tr>
                        <tr>
                            <td class="bold">Teaching hours per week</td>
                            <td class="center"><%= data.credits_theory || 0 %></td><td class="center"><%= (data.credits_practical || 0) * 2 %></td><td class="center"><%= (data.credits_theory || 0) + ((data.credits_practical || 0) * 2) %></td>
                        </tr>
                        <tr>
                            <td class="bold">Internal Assessment Marks</td>
                            <td class="center"><%= data.marks_internal_theory || 0 %></td><td class="center"><%= data.marks_internal_practical || 0 %></td><td class="center"><%= data.marks_internal_total || 0 %></td>
                        </tr>
                        <tr>
                            <td class="bold">End Term Exam Marks</td>
                            <td class="center"><%= data.marks_endterm_theory || 0 %></td><td class="center"><%= data.marks_endterm_practical || 0 %></td><td class="center"><%= data.marks_endterm_total || ((data.marks_endterm_theory || 0) + (data.marks_endterm_practical || 0)) %></td>
                        </tr>
                        <tr>
                            <td class="bold">Max. Marks</td>
                            <td class="center"><%= (data.marks_internal_theory || 0) + (data.marks_endterm_theory || 0) %></td><td class="center"><%= (data.marks_internal_practical || 0) + (data.marks_endterm_practical || 0) %></td><td class="center"><%= data.marks_max || 0 %></td>
                        </tr>
                        <tr>
                            <td class="bold">Examination Duration (in Hours)</td>
                            <td class="center"><%= data.exam_duration || '-' %></td><td class="center"><%= data.credits_practical ? 'As per scheme' : 'NA' %></td><td class="center"><%= data.exam_duration || '-' %></td>
                        </tr>
                    </table>
            
                    <table>
                        <tr><td colspan="3" class="section-title">Part B - Contents of the Course</td></tr>
                        <tr>
                            <td colspan="3" class="justified-text">
                                <span class="bold">Instructions for Examiner:</span><br>
                                <%- data.paper_setter_instructions || 'Nil' %>
                            </td>
                        </tr>
                        <tr class="bold">
                            <td style="width: 15%;">Unit</td><td style="width: 65%;">Topics</td><td style="width: 20%;" class="center">Contact Hours</td>
                        </tr>
                        <% units.forEach(unit => { %>
                            <tr>
                                <td><%= unit.title %></td>
                                <td class="justified-text"><%- unit.content %></td>
                                <td class="center"><%= unit.hours %></td>
                            </tr>
                        <% }) %>
                    </table>
            
                    <table>
                        <tr><td colspan="14" class="section-title">Mapping of Course Learning Outcomes (CLOs) to Program Outcomes & Program Specific Outcomes</td></tr>
                        <tr class="center bold">
                            <td>CLOs</td>
                            <% for(let i=1; i<=11; i++) { %><td>PO<sub><%= i %></sub></td><% } %>
                            <td>PSO<sub>1</sub></td><td>PSO<sub>2</sub></td>
                        </tr>
                        <% if (mappings.length > 0) { %>
                            <% mappings.forEach((map, i) => { %>
                                <tr class="center">
                                    <td class="bold"><%= map.co || ('CLO' + (i+1)) %></td>
                                    <% for(let j=1; j<=11; j++) { %><td><%= map['po'+j] || '' %></td><% } %>
                                    <td><%= map.pso1 || '' %></td><td><%= map.pso2 || '' %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <% clos.forEach((clo, i) => { %>
                                <tr class="center">
                                    <td class="bold">CLO<sub><%= i+1 %></sub></td>
                                    <% for(let j=1; j<=13; j++) { %><td></td><% } %>
                                </tr>
                            <% }) %>
                        <% } %>
                    </table>
            
                </div>
            <% } %>
        <% }) %>
    </div>
</body>
</html>