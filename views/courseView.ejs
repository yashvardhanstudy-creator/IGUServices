<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="shortcut icon" href="https://igu1.ucanapply.com/images/webicon.png" type="image/png">
    <meta charset="UTF-8">
    <title>View Syllabus - <%= data.course_code %></title>
    <style>
        body { font-family: 'Times New Roman', serif; line-height: 1.4; color: #000; margin: 0; padding: 20px; }
        .container { width: 90%; margin: auto; max-width: 1000px; }
        
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; table-layout: fixed; }
        th, td { border: 1px solid black; padding: 5px; vertical-align: top; word-wrap: break-word; }
        
        .header-cell { font-weight: bold; width: 35%; }
        .section-title { text-align: center; font-weight: bold; background-color: #f2f2f2; }
        
        .justified-text { text-align: justify; text-justify: inter-word; }
        .center { text-align: center; }
        .bold { font-weight: bold; }

        .action-buttons { text-align: center; margin: 20px 0; }
        .print-btn, .back-btn {
            display: inline-block;
            width: 200px;
            margin: 10px;
            padding: 10px;
            background-color: #6c757d;
            color: white;
            text-align: center;
            border-radius: 5px;
            cursor: pointer;
            font-family: sans-serif;
            font-size: 16px;
            border: none;
            text-decoration: none;
        }

        @media print {
            body { max-width: 100%; margin: 0; padding: 0; }
            .container { width: 100%; }
            .print-btn, .back-btn, .action-buttons { display: none !important; }
            tr, .unit-block { page-break-inside: avoid; }
        }
    </style>
</head>
<body>
    <div class="action-buttons">
        <a href="/courses-list" class="back-btn">Go Back</a>
        <button class="print-btn" onclick="window.print()">Print Syllabus</button>
        <button class="print-btn" onclick="window.location.href='/download-pdf/<%= data.course_code %>'">Download PDF</button>
    </div>

    <div class="container">
         <%- include('partials/courseDetails', { data: data, programme_name_display: 'As per Curriculum Framework', semester_display: 'As per Curriculum Framework' }) %>

    </div>
</body>
</html>